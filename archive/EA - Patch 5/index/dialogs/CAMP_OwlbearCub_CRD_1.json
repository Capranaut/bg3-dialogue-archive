{"ha331580dg5fdag4664ga3f9g42f7a4c252ba": ["Food! Hungry!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "d4d601a3-f2ec-5870-a224-07212db2a593"], "h7665b75eg7478g4ba4gae3fg704b31226f8d": ["I have food. Would you like it?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "2fce1b34-67b2-d9a3-1048-3a971f733893"], "h86f42972g7a16g4518g9ecag56fa9d8c6f3e": ["Want! Bite!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "f25edc26-63f5-4701-a625-1358c9c5fbab"], "he50a49fbg1994g4c17g9eecgd903d5ed9cf0": ["Go ahead. Eat.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "bbf4db97-6c61-9977-1f95-95b4be117e38"], "h3ce559c2g80d1g4373gb11fga79933a03525": ["Food! Eat! More!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "a2454a32-5af9-5009-2965-e91f9358541b"], "h12848284g5bb4g4b37gbc0agd1c9fc0631f0": ["Come on, then. Take it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "8894c77a-5624-df5f-8c78-492b5f4fdfad"], "he40ca598g28ecg4b0dg9037g4abee46f8708": ["*Your hand is suddenly empty - the work of a surreptitious companion.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "30fbb85f-a176-facb-96da-4a9c5a51d82d"], "hc844d2bega301g4eaegbe6agfeabbf46b766": ["Eat! Friend?", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "7e3073f5-b215-34f2-d9ba-df9c00a4af26"], "h7b2a676dg04e0g4d92g9931g086dee2cb732": ["On second thought, I'll have it myself.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "fc82d1b5-6c20-1e7d-3b51-f2bedd1acf84"], "h7eddac5dg5e0bg4a71ga88fgbb0ed683a658": ["Food. Eat! BITE!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "1124b7d0-b454-7de8-c80f-a0c6d3e7debe"], "hfd4e5e5bgd44dg4a8bg8619gf4b170f32432": ["*The cub's eyes light with hungry rage as he begins to charge.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "8fde2470-8780-d81a-26ed-604240e1d0bf"], "hfce3ca30gf3d7g4842g88a7g30c1c30ec828": ["Are you injured?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "573b3876-9ca1-8cbf-4b60-7ef1d96ca005"], "hf52fecfbg0059g4ddcgacc6ge7e0d55e623f": ["No. Strong. Big!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "6719bda9-7da6-730e-2a58-86a0bc3a095e"], "h8139bc66g7c63g4093g883cgedf872792fef": ["You <i>are</i> strong.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "bb4464ed-7f66-e071-6205-683350e45e6f"], "h4cff5715gf976g45c5g952fgd1e10e8a9c69": ["Big! Friend?", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "3011ce15-13b1-b79a-060a-466ab3f9909a"], "h15bf7927gfe69g40cag8aafg689cda7a1902": ["You don't look very strong to me.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "62686a51-bae2-9f0d-03e9-dd2bb1d6e2a6"], "h226697bcg732bg4b42g8f3fg2ad78a5bbf18": ["Show you! Bite!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "e1bcf8d3-af89-8609-0476-d52f14fbca45"], "h11ca2128gf66cg4bdfgaf54g89339cf399e4": ["<i>Step away from the beast.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "57af1594-e75f-6c9e-b226-d072b20edbad"], "he110262bgb4a7g4670g852age3f107e9dff7": ["*SCREECH!*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "9cb6fa4a-1777-cc5c-1cf6-74460cf06987"], "h9d5b394ag1671g4fe6g9685gb6494859a512": ["Bite! KILL!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "9c03f9ba-d743-4845-dc93-39f244ed235d"], "hb6eca660g33fcg4779gb313g15cfaab415d6": ["No, you will <i>not </i>bite.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "4e2884b9-f0a6-1d4f-e816-8b46d346a678"], "h9405c515gb00cg4a95ga5dag4ede0c98a197": ["Sorry? Friend?", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "9b51427b-9094-4374-c1f5-1db826dc15dc"], "hb9b792c7g5bb4g4003gac69g00bab94652c1": ["Liar! Bite! BITE!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "828a8023-5870-1a57-42aa-c84ee2faa9ec"], "h4d5aae2dg4dcbg4b61g9083geec3cedf7df0": ["<i>Meet his charge.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "03b39ab5-10d6-cee3-4e13-ec5472b6f897"], "hfe2cbb78g175ag4650gb416g057b2a7c339b": ["Then prove it - defend yourself.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "87b172a8-f9ba-7049-0d15-741e4ea98de2"], "h72b4a88dg4c04g4835gace7g3d27d198c4ca": ["Go away. You're not welcome here.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "580d34f1-dfb3-7b65-f88c-7a156b958b1e"], "ha9546974g1f9dg4179gbf92gc2218e6c79fd": ["Bad! Mean...", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "4b624fb0-6353-9ca9-d684-e7a33ddf0fa8"], "heafcbf43g301bg41b7g8473g41ee055aa96a": ["<i>Attack him.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "187a6000-0068-9721-7e1a-1ce0dbca92a7"], "h52a3f3c2gb0c4g4497ga8d9g7cd056d85b6d": ["<i>Leave him be.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "881aab12-0f4e-8178-5476-54bd52e7f1ef"], "h551c0e3ega487g4bc0gad23gf5f2db50b1a1": ["*You recognise the feathered creature - it's the owlbear cub you rescued.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "40e9beb0-204a-24a4-b8c9-8b754f975b56"], "h4b97813ege4b0g45fcgbc46g8d7389ab5068": ["*Hoo. Hoo-hoot.*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "6978c4aa-0201-4701-c214-9f8dc312fde4"], "hfc6e553ag53afg4da6gac71g5a2016c870d3": ["<i>Fetch a piece of food from your bag.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "296b088d-8776-a44d-7913-a1106412982b"], "h9ea3f7c4g0803g4b78g968bg2d7497135a7f": ["*The cub's eyes lock onto the food in your hand.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "89207b0a-6862-89b6-436d-05e89da5bc57"], "h24885e4bg5ea8g4ff6g9395gb12eabdc9af8": ["<i>Toss the food to the owlbear.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "4f4e3939-d235-0983-c5a3-c27b9e1ff897"], "h7ea913b6g3dceg4cecg8a81g6bb20c63e2a4": ["*The creature gulps the food down - it seems he hasn't eaten in some time.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "0a784352-de68-4e3c-46c9-75f0d80516bf"], "h8837a4fag9bb8g4fd6ga365g4eaff695e2a7": ["*With a hungry chirp, he steps forward - he wants more.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "8e2d1119-bf88-ffa9-392b-1551ac41bb51"], "h65926808g803fg4a90ga171ged667eb57151": ["Bah. Now that you've fed it, we'll never be rid of the beast.", "58a69333-40bf-8358-1d17-fff240d7fb12", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "4a2795cf-786a-0d1f-4362-3837aa92fb22"], "h645000cegf2afg407aga056gb1b3cd07ab9a": ["No! Run!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "653f5ab4-d5b9-5660-709a-06ec89929e4f"], "h10f1cfdega89dg4b2egbb56gd0e62364e607": ["It'll be back for more rations, mark my words.", "58a69333-40bf-8358-1d17-fff240d7fb12", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "a63c2f7b-c9af-e978-ff27-6e76d41b0c43"], "h99617d70gc356g4e04g9a9ege60a8c6807b5": ["I'm not chasing after it, if that's what you're thinking. ", "3ed74f06-3c60-42dc-83f6-f034cb47c679", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "97ebaa22-4517-5b58-0a24-f8a2c6f64fb8"], "hfc01c440g375eg4385gb2adg4f7b5211f60e": ["It'll come back in its own time, now that it knows you'll feed it.", "3ed74f06-3c60-42dc-83f6-f034cb47c679", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "c1e14cca-7584-7af9-0416-4d9b837a0b7a"], "hd33869f9g03bag4a55gb996g9d567b7b603a": ["|Shame. Perhaps it will return.|", "2c76687d-93a2-477b-8b18-8a14b549304c", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "511a7705-52a6-4ed7-1eed-bf6352c919c0"], "ha847b19fg0c46g4d70g934ag19de24c8eee5": ["|Friend! No! Come back!|", "0de603c5-42e2-4811-9dad-f652de080eba", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "c15d60b4-4fca-8520-3874-5c597b3d4426"], "h3fbf6401g388cg480bgbf7eg268573edf81f": ["Oh now look, you've scared off the little snack.", "c7c13742-bacd-460a-8f65-f864fe41f255", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "eced5744-d7c3-ebf0-75a4-669d1d3a60d9"], "h13b97f8bg1ca7g4deegb5c4g84da3732f1a1": ["|Werewolf!|", "98b9a4da-d3af-494e-890b-c8ec85d3146d", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "96afa3c2-0858-954e-10f8-c31fff2e0175"], "h5b36bf12g9bcbg4745ga29bg1c8ed238faa6": ["It'll be back. You sure you know what you're in for?", "c774d764-4a17-48dc-b470-32ace9ce447d", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "e9b2c5c6-a118-cdb7-dc99-eafa7248b456"], "h8050f810g37abg4c18g9067g5ab5336758ae": ["I stand corrected.", "ad9af97d-75da-406a-ae13-7071c563f604", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "081c9950-ae48-8821-0781-e98572becc54"], "h097c7553g274bg4eabgb51egcb21d030ea99": ["*Alarmed by your companion's approach, the cub flees into the forest.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "2bb02121-2f41-fd85-8f5a-20934b373d53"], "haed1fca5g4d62g4ef0g96a4g27d4a7860549": ["*Screech!*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "999140fe-afd0-4fea-a341-bfabd5a6c3d1"], "h15ea7677g4e76g4af2g8f72ga03b22d54c1e": ["Careful. Once that thing's eaten through the camp, it might start looking at <i>you </i>hungrily.", "3ed74f06-3c60-42dc-83f6-f034cb47c679", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "35ac1c9d-4177-a497-9eef-1427c69491b9"], "h74d41cb3g5941g4519g9697gc51e3bd2fb32": ["|That cub could be a powerful ally someday.|", "2c76687d-93a2-477b-8b18-8a14b549304c", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "8f119969-840b-00b9-431e-44ec26462696"], "h6aa193afge5d2g471cg8844g4f04b5650ffb": ["|A new friend!|", "0de603c5-42e2-4811-9dad-f652de080eba", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "b59b8754-bdad-9f6b-56f2-726c461977d9"], "h6f688d39gde99g4bdbga897g05dc855ee9bc": ["What a delectable little pet.", "c7c13742-bacd-460a-8f65-f864fe41f255", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "dd38c6bf-5888-2a94-5b0e-2db9123b8301"], "hc7bfc8eag4618g4d34ga50cg128cf9e3b73e": ["|Grr grawr I'm a werewolf.|", "98b9a4da-d3af-494e-890b-c8ec85d3146d", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "0a5a05a9-dfb8-5eda-2b43-f0fd24293339"], "habb6a22dgedbcg42d2ga48bg68ea4f0f18ef": ["Now <i>there's</i> a feathery face I didn't think I'd be seeing again.", "c774d764-4a17-48dc-b470-32ace9ce447d", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "f1b010ee-0caf-63ed-a252-7130bfa36087"], "h749bb58fg624cg4663g856fg279a7990da05": ["The hand that feeds is the hand that's loved. It'll never leave your side now.", "ad9af97d-75da-406a-ae13-7071c563f604", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "0e2ad6a8-257b-7676-2cf7-7050ef13b9bb"], "hbf0d8055g3483g4f37gb7f7gb04af3587c67": ["*As he approaches, his foot lands on a dry twig, snapping it in half.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "7904c9f1-ab9d-1b13-0dda-41497d113fa8"], "haea66582g0478g45d4g8889g0de9fc62bf48": ["*Frightened by the sharp noise, he turns tail and runs into the forest.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "3dc07c8c-5a91-37db-b62b-7c5a8cc5a1e5"], "h364d3db6g2ed5g43c5g9a0ag8b5f48e54aec": ["*Hoo-hoot!*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "1bd0338c-3841-e37f-636f-b0eecf390ab9"], "h01cd283cg6407g4950g8d78g91eb7033c5c8": ["<i>Keep the food held out in front of you.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "44589cb9-c3e6-724b-4fe4-de361b543e7e"], "h3e6b439ag6e24g4d30g8ca8gea3ea840d833": ["*He takes a hesitant step toward you, his beak chittering hungrily.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "68f82739-c9da-7ac4-c9e0-9e58ae991801"], "hcaaf0f17g99bcg40f6g8f11g492bf7421ad6": ["*Chirrup!*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "438d9444-1399-d98f-66c5-6dfd153910b7"], "hdecdaa93g511fg47abg9482ge2b3493933b7": ["<i>Eat the food.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "084704a0-4a33-2146-57d4-b5f6ed6c56d4"], "h753f2e8agd00cg4906g8b84gb2a7fff32a83": ["*Any food you had is gone. The owlbear will go hungry.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "16df6c29-32e5-1b23-7950-d443d587b8b0"], "h7919d8fdgcd28g4be5g8eafg59bfeb4595c0": ["<i>Wait for him to approach you.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "ab7ed97b-44e7-67ca-6048-882a0f91f92b"], "hf05c4cafgf9acg48edg9f1bg0885ce8675d6": ["<i>Beckon him closer.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "56f02d09-3422-1d2c-7f63-c1d56946f3c6"], "h603b68d2gdbbfg4e04gbaeagb4c999f55bf8": ["*The cub tilts his head. He does not trust you - yet.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "95267f07-9ab5-964e-9569-ac4b6570646e"], "hfeaf45e4g7592g41e6g9394g581ddb41d9c0": ["<i>Keep your distance.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "3fcda9a7-d19d-d56e-7543-cb8ec57f4f70"], "hc9752d1dg4e6eg4757g814bgd98b59dceefb": ["*He steps closer hesitantly.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "9ac035b5-5ba5-8066-9441-df6fafc38ea7"], "ha9e66c80gc7efg4528g8daag935a397f0cae": ["*Hroo-hoo?*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "ee7e368a-414f-9989-0f1a-4cb7a54afe9e"], "h34c6198bgbc60g4116g8a67g66e4ca8c674f": ["<i>Move closer.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "86b4f2be-d7ee-e85c-9608-8f28ad333394"], "h414a64dcgc509g45b1g8048gf53e5f744f1e": ["*Your movement angers the cub. He readys himself to charge.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "428ab992-60f6-ae60-16fb-d169385046e4"], "hf39bab73g5e38g490cg8c4dgee4a7102b2a2": ["<i>Move out of the way.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "7e800c32-9b14-4ad9-ab1a-b275df2665e0"], "hbf7a1e13g4fcbg4788ga111ge5afea2f8bd7": ["*SCREECH!*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "0daf43cc-ac40-1bdf-2ade-d83df316e41e"], "h2bc41b2eg308eg4d2dgaa23g6df0a7357f28": ["*Squawk! Squawk!*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "b9478a80-a579-80dd-0e7a-5a02acb8ae86"], "hccdec408g9b27g4a4egabb4g5217865b5aef": ["*You are too slow - the owlbear readies to slash you.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "c4133b18-813e-dd7b-b94a-8ccf185e761a"], "h3cc381cag8257g4781g8d54gc01f006c2610": ["<i>Hoot softly to calm him down.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "fb4f1813-bef0-ed90-f4a9-da0e04c87c8f"], "h17a1a0edgae1cg4cffgb73egcd4f8e7c0ace": ["*The creature slows, his aggression replaced with curiosity.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "553ee90c-ff05-5053-c19b-c66414ec5d94"], "he84c439bg139ag4e7fg8b9bg390aba9f40ea": ["*The cub hisses - you might've hooted a threat.*", "NARRATOR", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "778295c8-9d78-7b74-1d05-68662c5b3146"], "h1ba08543g86adg4ef8g9d96g1a6b238223ce": ["*Hiss!*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "3d388020-8d87-ee2c-91e9-52d576980c02"], "hbb2b603cgf37ag4688ga9fege65241f7da6c": ["<i>Brace yourself to meet his charge.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "aac86e49-6712-94c0-046e-3845f126d5ca"], "hd381caffg34deg459ag8c93gafb3c21459c7": ["*Squawk!*", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "ad294763-906c-c75c-9cfc-0e24165bcf3a"], "hf707c05bg0e60g47bbg8811g4c7756c5176e": ["<i>Attack him.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "69f530ae-7b79-b347-534a-753cdca10269"], "h2f3044b8g6b05g4020ga076ga1950b5f28d4": ["<i>Attack him.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "f02d6020-b1d8-d7b7-2cdc-9bf590fd1faa"], "h4d8b5ea5g4620g43f5gaa1dg6c49cd95367d": ["<i>Leave him alone.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_1.html", "5edc5033-bee2-1b47-7236-a95994405f4a"]}