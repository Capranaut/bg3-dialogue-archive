{"h7f63a52fg45f5g4069g9022g1cc594673010": ["*Howl.*", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "034c967d-9051-ab30-7ed3-7605ff7fa041"], "hfecf3d4fg8dd1g45aeg89d1g171f61b967ae": ["Stomach hurts. Stomach always hurts.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "5b36d583-7480-bc06-309e-0e1cc9a0e2d5"], "h22aa95aag63cfg4783gb83fgdb4989d443cd": ["Hey. Hi. You're here. What're you, then?", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "08c446fb-cf48-e8d1-287c-1e0f39222d35"], "hea6c9617gcb84g4b4dg8d08g031fd03d1545": ["Well, I'm human.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "ababa6aa-f811-bfbf-99f5-2dbede8c051d"], "h0562e742g2431g4c33gb574g198cddb1e2b8": ["Soft meat, uh-huh. That's what I thought.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "e7cee454-fd3c-f980-9e46-6071cb381a88"], "h28eb4969gfe8fg48b5g8df8g1d3fcd04d268": ["I want the meat. Can't help it.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "3cb6447f-f8ed-eed8-4e6f-9d6c41bb7ff9"], "hf5a5d8d8g9ff4g4dbeg8fa2g2a304793ed5f": ["We gotta eat. Better run. Better git. Or it'll be you.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "bf9214e4-d0da-ebae-9da3-7028f1a08d29"], "h66e1cbfbg9d81g47c8gae7cg0a2e6fdfa47e": ["I'm a dwarf, of course.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "19d97dd9-9520-10f2-46fe-6e7e9a8a1673"], "h06034c05g4444g417cga953g97b755cb9cc5": ["Mm, shortmeat. Yeah, that's good. ", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "2a4f2713-abc7-369d-5198-7ab310dadad7"], "h110695c7g7dbcg449bgba0cg5a072ed9df7e": ["Just a halfling, out and about.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "20a4dc76-0078-75e0-e0c9-0765c158394b"], "h636d33d3gaf62g4ef8g90aeg3f54f662fbd9": ["Never seen a gnome before?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "b340840c-52ed-aa83-591c-ddb8544a79b5"], "h0759fae7g3c97g4cd4g9db6gd1fb984c9b63": ["I have elvish blood, if that's what you mean.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "43fad52d-f40c-7e37-c4f7-3404dc7968cd"], "h063d3a1dge60bg4d10g867eg79c77155ce49": ["I have elvish blood, if that's what you mean.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "43fad52d-f40c-7e37-c4f7-3404dc7968cd"], "h281443feg28b4g4411g85d3g63830140c2e2": ["I wouldn't expect a hyena to recognise drow.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "e41efaad-f59d-d2da-c726-5f0dea0f6445"], "h17569fb8ge38dg4afegb28agf55df5f2ef65": ["Gray meat. Tastes like earth. Tastes like pain.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "d1556aeb-a129-5eb1-d42c-949175b46fd3"], "he3b083a6g9e85g45a9gb986g56d24418e846": ["I'm a duergar. Don't you have eyes?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "669ca531-aff8-2f19-3bdc-9a1cb2328623"], "h00d71867g43edg444cga1bbgeda4cf49206d": ["The horns didn't cue you in? I'm a tiefling.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "93fcbbe5-f2fc-c759-40db-03122d9206fa"], "hc25c43b9ge94ag45b3g8666g5a27a3d52752": ["Cursed meat. Warm meat.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "2c57668f-68b3-7004-ec0c-e4edcdc5e872"], "h92fd2002ga257g4033gb2d7g6d54ef84d843": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "5b314d70-e2b3-567b-8dd4-085255714491"], "h266cd879ga56cg4878g8b60ga65d0496c2cf": ["Tough meat. Want to chew down to the bones.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "9a08ea70-40cc-9c3c-2e09-89dada9a5d8a"], "h303a0557g3632g4f25g8367g1315ab2ca577": ["I'm a githyanki, beast.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "6001028e-da13-aaa6-04a2-339b82c8adfd"], "he07c8d9ag0555g4218gb4c7gee2fdddfe0d4": ["Half of me is orc, if that's what you're asking.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "aab3955e-d014-3cb3-80a4-8d899f407c3f"], "he92c223bgfe5eg464ag8d4aga7ddbbdbd386": ["I'm not from this plane.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "04bc6c1b-9e2f-c633-ddff-f454d06b97ec"], "hc7876f7bg0008g4c02gaba5g5b42aea4db33": ["Strange meat. Maybe you glow inside.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "64fdbad6-7a43-6805-f11e-6cc0e71f0509"], "h3622ef15gb46ag4330gaa52g94421107e01a": ["I doubt you've seen anyone like me before.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "5129ba12-e101-a021-e105-278566ab8378"], "hab9b7be5g94ccg43bcga4fbgbecb0887ef86": ["I'm a god, walking in mortal flesh.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "1c163ee5-3029-c311-f62f-9d1b38500833"], "h1c994781g390fg4021g9417gb71f8282e0e0": ["Oh. Holy, good holy. We follow Yeenoghu holy.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "d623d547-84d6-626f-d408-741d08609b3e"], "he71b7a1dgd185g44bag9210g7b30296bdd9e": ["He makes us hungry. Always hungry.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "97d750fb-3d71-3869-e440-bdb041412cf3"], "h26ebe514g55a4g4044gb5a8ge3842951eaa4": ["Heh. Heh. You are?", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "d198d862-7bf5-3db8-06d6-622eaf3d3374"], "hb289b4f5g4072g49a6gb91fg1b753bff1666": ["What does godmeat taste like? I... I gotta know.", "9c5f8832-a4c3-43c7-a860-4d7b4aa309b5", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "990c640a-166b-e45e-cd0d-bfd6f0bb9a73"], "h41331ebag432eg4031g9193g5dc3506ee9f9": ["<i>Leave.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Plains\\PLA_ConflictedFlind_Hyena_002.html", "b1f07775-8208-a51d-7aac-f550cf1f8b37"]}