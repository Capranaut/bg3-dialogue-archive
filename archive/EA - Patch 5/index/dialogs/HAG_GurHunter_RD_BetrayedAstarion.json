lection_Dialogs\\HAG_GurHunter_RD_BetrayedAstarion.html", "66ee08c4-cede-406f-a716-7e99b4a71c1c"], "h27423437g96d1g49d3g9c3ega34da0e3fee2": ["He's gone. There's no point in fighting over it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\HAG_GurHunter_RD_BetrayedAstarion.html", "66ee08c4-cede-406f-a716-7e99b4a71c1c"], "hc9e2685eg2119g4e24gb629g8b28dbae51c8": ["I'll breathe easy knowing my neck is safe from his fangs.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\HAG_GurHunter_RD_BetrayedAstarion.html", "f24cb145-48f6-44b2-b4e0-0897b99e49f3"], "h262191dag3306g401bg8a11g1ebe19947712": ["Astarion's as good as dead. I won't waste another thought on him.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\HAG_GurHunter_RD_BetrayedAstarion.html", "f24cb145-48f6-44b2-b4e0-0897b99e49f3"], "h25102d7cgbf8bg4521g8bbfg4551a4c07dbd": ["Looks like nobody's being eaten up by regret then. Let's leave it at that.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\HAG_GurHunter_RD_BetrayedAstarion.html", "f24cb145-48f6-44b2-b4e0-0897b99e49f3"], "he03f34aeg7744g4a4egbd55gbe4235a328c0": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\HAG_GurHunter_RD_BetrayedAstarion.html", "f24cb145-48f6-44b2-b4e0-0897b99e49f3"], "hf876a157g7da8g4391ga228g381501a8ca22": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\HAG_GurHunter_RD_BetrayedAstarion.html", "f24cb145-48f6-44b2-b4e0-0897b99e49f3"], "h77081590ge149g4cb9g9bb3gb2cb6120f843": ["| We are in agreement: A. (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\HAG_GurHunter_RD_BetrayedAstarion.html", "f24cb145-48f6-44b2-b4e0-0897b99e49f3"], "h93a486e6g086bg481eg9c47g194aac486720": ["| We are in agreement: A. (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-968