_Dialogs\\GLO_Astarion_RD_VampireRevelation.html", "aaf0df0e-a575-4ad0-abef-c86f16f8f049"], "h244fd48fga31bg49edg8d37g6c823f70c943": ["| We are in agreement: B. (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\GLO_Astarion_RD_VampireRevelation.html", "aaf0df0e-a575-4ad0-abef-c86f16f8f049"], "h2c84e2c9gf563g46d2ga94eg02d78114a913": ["Well, he's gone now - for better or for worse.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\GLO_Astarion_RD_VampireRevelation.html", "aaf0df0e-a575-4ad0-abef-c86f16f8f049"], "h0c76ff50g4bc0g4633g8c85g405eb203ae5e": ["Astarion was a vampire. He needed to go, no doubt about it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\GLO_Astarion_RD_VampireRevelation.html", "feca8860-f031-4a0c-8b3f-946fa2d334be"], "he53dd021gdedbg44a3g9bc0ga6f512ac105f": ["You acted quickly and justly - as the <i>ghaik</i> covet minds, so do vampires covet blood.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\GLO_Astarion_RD_VampireRevelation.html", "feca8860-f031-4a0c-8b3f-946fa2d334be"], "he8e0197eg3c56g4051g8330g0fdba67c074e": ["Wrong - we had to get rid of him. We've enough parasites to handle without a vampire as well.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\GLO_Astarion_RD_VampireRevelation.html", "feca8860-f031-4a0c-8b3f-946fa2d334be"], "h1e92d59ag9199g451dgad55g4cb50e6e87e9": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\GLO_Astarion_RD_VampireRevelation.html", "feca8860-f031-4a0c-8b3f-946fa2d334be"], "h2f4cafc4g5b9dg40feg8561gc068f53b42e1": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\GLO_Astarion_RD_VampireRevelation.html", "feca8860-f031-4a0c-8b3f-946fa2d334be"], "h14ce924fgbf39g42e1g9dceg4aea4c74c31f": ["| I disagree. I want option A (Karlach