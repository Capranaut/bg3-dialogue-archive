e_RD_AfterFight.html", "f4991b7e-3c87-db4e-98e6-c27e3165686e"], "h2fa54248gbedfg4657g889ag1aad21bdb3a6": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "f4991b7e-3c87-db4e-98e6-c27e3165686e"], "h953a9171g2daag4cb7g9a45g9ad5ca2c004c": ["| I agree. I want option A (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "f4991b7e-3c87-db4e-98e6-c27e3165686e"], "ha6c12aa4g341cg458bg8aefg82be48d1e4b0": ["| I agree. I want option A (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "f4991b7e-3c87-db4e-98e6-c27e3165686e"], "h90a106c9g8756g4992g9256g5ad401251382": ["We should be more careful next time.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "f4991b7e-3c87-db4e-98e6-c27e3165686e"], "hf0a94e88g83ccg48bfg9e54ga41da76c5713": ["Enough squabbling. It's over and done.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "hcf0ada5ag9788g4c33gad31g91560c952448": ["Enough - there's no point in dwelling on it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "h9a1ba1a7g653dg4fedga233gb807f4e60b92": ["Look, they're dead. How about we all shut up and move on?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "h8ce7da09gd129g44cbg9c1bg5edde8f3fa9a": ["Let's just put this behind us. <i>Far </i>behind us.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "hf051b8c8gb4e2g4a83g8028g9aa50861b277": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "hd3ee7a5dge369g4491g8c7ege9e521a6a56f": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "h8c2bd81fg0ad5g431ag98deg2824dc68d474": ["| Well we don't need to decide right now. (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "h290a60f0g473eg4b29gacd6g166c1a0fbb3b": ["| Well we don't need to decide right now. (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "h83760d28g545cg4a81gb59cgfe55469a8056": ["Well, it's too late to change now.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "5148dfc3-37cd-29c5-0ada-67560bee515d"], "hf2396ec1g01cbg4a40ga560gebcfa71d1647": ["Sing it loud! Let love win out!", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "hdadfbaa0g463eg4076g91bbgf58f7cfc8850": ["Glad we could find some common ground over the dullest of matters.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "h37f1d4a3gaf3cg4d02gac3cg922214701fec": ["Aww, what a wholesome bunch we are! A shame they're already dead.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "h1ef34c48gebacg42acgb624g0e333917fe6b": ["A consensus? Wonders never cease. Let's move on.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "h9713c5cbg4e16g445cga1cdg3447f1f571e4": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "h230f378eg6a2dg4adeg9287g023de335915c": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "hb354073fg361cg4eb2gb2f6g324537f9a6e7": ["| We are in agreement: A. (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "h7686c044g69cbg412eg88d1g8792b9f614d3": ["| We are in agreement: A. (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "hdb300a10g1f78g49ffgaa1bgc0e4d71b1b96": ["What's done is done, but we should think twice before barging in somewhere next time.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "8c4bdb53-75c1-8129-1a6c-7e804ac2f87f"], "hb97a130fg65c7g40e0g873cg5ea59425e6f0": ["What do you know - something we actually agree on.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "h6f42cde0g90abg4119g9f5fg4774b4a09256": ["Agreement. How dull.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "hd593650dg7c8bg44c5g9893g8b5522ed6c85": ["I'm glad we can come together and agree.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "hdb2bf75bg03d2g40f1gad43g7d3cc3982623": ["Well if we're all of the same mind let's just move on, yes?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "ha78ba145g177cg43b9gbe5bg38ee5de2723e": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "hcdae2663g4b90g4563gba1bga408b8710339": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "hb63f2722gbbf3g4de2gbac2g967c7626e480": ["| We are in agreement: B. (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "h99ea25cbgfe59g46edg82d7gaa020869c67a": ["| We are in agreement: B. (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "h6690e49bgd94cg4a7eg9ca9g340385c90ee6": ["I'm glad we can agree on this. ", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "98c5362e-c660-55ce-33f1-4783cb420a4a"], "ha199ff8fg9dbfg45d3ga280g9bf51a45875f": ["Come, now - love is love. They weren't hurting anything.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "hde028a38gd053g4d65g81e0gfe1cb2e59c8d": ["Ridiculous. We needn't go poking our noses in every crevice.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "h2b47d12bg6f64g4711g8dd9gcab1d4271fb5": ["Don't be heartless. After all, coitus interruptus is coitus horribilis.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "h95fdc455g0b61g4354gbc2fgcd33267b6d59": ["No. We've enough things out to kill us as it is without provoking more.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "h97924b42g465eg4134gbea8g13ae56d98fc3": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "hed01621cga6d1g4650gb02dg01138cd54a42": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "h72db086cg7b05g42d6g93b0g62a8a57de009": ["| I disagree. I want option A (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "h8883d6ffg8659g484ega94cgcd79699b32b4": ["| I disagree. I want option A (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "h65f10055g7b4ag4c61g88ccgb2ff5499d5c0": ["We could have avoided this. It's not our decision to make who deserves to live or die.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "6de9037f-e44c-aa57-5e56-7c55197e3b62"], "h22c7012ag9311g448dgbddcg5999c3d4af66": ["You got it. Two monsters down. A whole lot more to go!", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "h797b7b22gc000g437fg857egdb32d8a5754a": ["Yes, a fine battle - good exercise for the wits and muscles.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "h9a0a7b76g019ag436fg9d17gce040790c54a": ["Exactly! We did the world a favour. Imagine if they'd had cubs.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "hccbeb719g6f8fg49a6gac60gda922602c00b": ["Yes. We could've shown discretion, but no matter. We won. They lost.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "h3dfbd3e9g9c9cg4518g8b29gc10d6f0f1e2b": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "hd87f574cg6918g4161g8c2egaf4585957eaf": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "h634eebe1g0bfcg470fg96e9g14b221d93059": ["| I agree. I want option B (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "h4aca0045g3ab6g413bg83d3g4600728837c4": ["| I agree. I want option B (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "h3e471ea7g8f35g45acgb200g6078becbdb1e": ["Yeah. They've probably killed dozens already.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "9ce64ead-4b13-dccd-d922-e88fdc65864a"], "hc9f123b5gf9f8g40c5gacecg3bc84e4dd56e": ["Chin up! That's two monsters down and... a whole lot more to go!", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "hc3f6bc4bgfac1g4f80gb736g373f471f5111": ["Enough moaning. It was a fine battle - good exercise for the wits and muscles.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "hd9bf745dgd1b0g4791g93c1g91d962728746": ["What? We did the world a favour. Imagine if they'd had cubs.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "h971b77a8g0e59g4434ga126g7a2138a585b3": ["No. We could've shown discretion, but no matter. We won. They lost.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "h3c2e2761gb0d3g4784gb7f6g0e4040839ebe": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "he41dc5f6g5ee2g47dbgbb9dg6337f8b268df": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "h4b1ce787gfd9cg4e3aga1fcgbbcb51cf9d8d": ["| I disagree. I want option B (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "h32b462b2gf238g4124ga10age098d5f0d294": ["| I disagree. I want option B (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "h10fc3e9cg2874g486eg98eagf89fec54fe5d": ["They would have killed someone sooner or later. They've probably killed dozens already.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "e634be1c-a37b-c53b-5ce3-1dcd17644d0a"], "hddf7e126gd2dag481bgbd84ge94cb172455f": ["Come, now - love is love. They weren't hurting anything.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "0da91061-0d32-d2e5-89e5-0ae3a0acb141"], "hfbe979a6g8c7ag4529g9d8fg1d5ce9817f62": ["Ridiculous. We needn't go poking our noses in every crevice.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "0da91061-0d32-d2e5-89e5-0ae3a0acb141"], "h25a9ca9eg584ag40b0gb7b1g14eee7ebd884": ["Don't be heartless. After all, coitus interruptus is coitus horribilis.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "0da91061-0d32-d2e5-89e5-0ae3a0acb141"], "hfcc83e23gf6f9g406eg92d6g6e694de29ddd": ["No. We've enough things out to kill us as it is without provoking more.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "0da91061-0d32-d2e5-89e5-0ae3a0acb141"], "h813d4586g70a1g4c14gbb87g20ae0d24c17d": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\FOR_BugbearLove_RD_AfterFight.html", "0da91061-0d32-d2e5-89e5-0ae3a0acb141"], "h65eb1061ge463g430cgbccbg65ae89535772": ["_", "e0d1ff71-04a8-4340-ae