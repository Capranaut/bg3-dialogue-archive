n_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "2c5416b5-34f5-44af-a66f-f4a4ef05a687"], "h71421128gb906g4cbeg9764g79f1ec0df73a": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "2c5416b5-34f5-44af-a66f-f4a4ef05a687"], "h9cd7e5b0g0aa3g47c3gb827g0d0cb2a5cb0a": ["| I agree. I want option A (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "2c5416b5-34f5-44af-a66f-f4a4ef05a687"], "h8b7625ebgf16dg46eeg91cbge56e71860c03": ["| I agree. I want option A (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "2c5416b5-34f5-44af-a66f-f4a4ef05a687"], "h1dd0b489gdd71g451dgb159g04b5fe24e183": ["She lashed out in the heat of the moment. We're all capable of the same.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "2c5416b5-34f5-44af-a66f-f4a4ef05a687"], "h83827d9fgc072g4412gb7c0gb38e7f791f4b": ["An unfortunate tragedy, yes. Kagha couldn't have foreseen it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "hb5cd48d6g7133g4b3aga537gc34c9ddcc7cd": ["A logical outcome. Kagha identified a defect in her grove, and the serpent removed it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "h581f067eg8580g4de7gb83dgef282ba27274": ["Precisely - it was a sorry accident, nothing more.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "hde0e0633g98a4g474cg8121g2a10a667b5fd": ["| I agree. I want option A (ShadowHeart Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "h3dbeb78egba9fg4028gb46dg323afe3f3af2": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "hee361b82gd3a8g4867gb084g10027b2bb9cf": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "hc78dd911gee63g4029gafc1gccacc6402aea": ["| I agree. I want option A (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "h75e3e147g8fa1g4419gb802g19968f64d8d3": ["| I agree. I want option A (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "hcef370eagb3f8g4b8dgb344g1e4c50fb2a13": ["The girl stole something, and matters got out of hand. Leave it at that.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "ab089411-2c83-43ef-a895-752966db7bbd"], "hc8863b29g36eag4cd6gb114g85259e3eb833": ["What's done is done. At least the girl didn't suffer long.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "h0cb917b4g4817g496eg808ag01228c25d6b3": ["Enough. The child is dead. No need to prolong the matter.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "hece293f8gc622g4fadg8563g96e464b40f5c": ["Whatever the intention, the child is dead. Debating it won't bring her back.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "h639156ceg1680g43b2gaf4fg90ff91e8e7ff": ["| Well we don't need to decide right now. (Shadowheart Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "h0b9fcfbdg0f39g4b03gb085ga7177debc1a0": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "h0cdd1ccfg8e51g46caga819g2bf0c01d0080": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "h9672bacdg588dg4aa3g8f73g2bf81f13ee2e": ["| Well we don't need to decide right now. (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "hfe959f95g0207g4732g9630g7f923757e5d3": ["| Well we don't need to decide right now. (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "hccf30f2fg1efcg4fa5g957bg2dade4938602": ["The grove's tense enough. Let's not keep arguing here. ", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "900b969c-e45c-4fa0-9e5f-14c8e1c9a3eb"], "h8275935cgae72g48c9ga1cbge9c4c51a1f15": ["A shame to see. At least the girl didn't suffer long.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "h3245bcbcg025fg42d0g8cebgb1e7e32ad210": ["The girl was a fool to cross Kagha. The refugees would do well to heed the lesson.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "hbb6aeb8fgc41cg4818g954bg276c11a6572d": ["Yes, it was unfortunate, but hardly murder.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "h75f98092g1ed5g47bdg9c3cg20ee1aec1a95": ["| We are in agreement: A. (Shadowheart Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "h641074eeg2f78g4352gb1c6ge7bda0bb974d": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "h3500cdadg6b0fg4201gb5b7g68c6833a4e55": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "ha8a0c78dgd631g4cd3gac8fgdcddda121268": ["| We are in agreement: A. (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "h22d9d7d5g329bg49bfg82e7gf3fa2a548c00": ["| We are in agreement: A. (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "haa16d03dgac86g4cf7g956ag0e6023799db9": ["It was a horrible accident - there's no point in making things worse. Let's get going.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e469edee-66d8-49eb-9bf9-d13cb0196081"], "h65a0d093gbb3bg4ef9gbfa7g30dc793672b2": ["Kagha knows no pity. I suggest withholding yours in kind.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "h186af9f4gb03cg49c7ga207g242c675201f0": ["We witnessed the elf's style of justice. Perhaps we should introduce her to ours.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "h1f804ce3g4243g41dcg9c4eg331657895cfd": ["Let's get on, before the druids decide we're on their list of enemies too.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "h0ac55d8fg53bbg4fe7gb1d4gb9bb9d2d2f10": ["| We are in agreement: B. (Shadowheart Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "he386b23eg62ffg4fe2g8dfdg6a3eb8746062": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "hfcb97379g1746g45a0g8929gd49ec1752727": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "h92f30e13ga8ffg4ff3g9986g0238e81b8424": ["| We are in agreement: B. (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "h41c9aabfgd00fg458ag8099g8fca2fe34706": ["| We are in agreement: B. (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "h983df99bg6137g4a46g9263g1209357f7779": ["At least we all agree about Kagha. Maybe we'll get a chance to do something about it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "99eb8d2d-8f35-43d2-ba15-5500d9ca601d"], "h78bcee0fg7caeg44d8g9567g0a1610908846": ["An unfortunate tragedy, I'd say. Kagha couldn't have foreseen it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "h9e442cfag6600g460ega344g5bf3b1df2450": ["A logical outcome. Kagha identified a defect in her grove, and the serpent removed it.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "h07e6e34fg2f94g40aeg8b02g80e4e191918d": ["Hardly - it was a sorry accident, nothing more.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "h551d5c7cgb0b4g4226g843fg4de5465110d3": ["| I disagree. I want option A (ShadowHeart Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "hbba8b90cgc992g407aga94eg0be27e0b35fd": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "h3baa25a7g05a1g4ecfga3a1g384fcf6abdc4": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "h00d8af14g134bg48feg9a20gf5ce750ad17f": ["| I disagree. I want option A (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "h5e500cc8g27f4g4311ga390gea00ceb127a8": ["| I disagree. I want option A (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "hf04994ccge61fg4c65g8043gce8e5f4c1702": ["I'm not comfortable being judge and jury. I don't think anyone wanted the girl dead.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "e9acb0ab-40c0-4ea6-a712-4e8693811e55"], "h64163a75g3900g484egaef7gfe90d6cba742": ["There's blood on Kagha's hands - enough to dye the Chionthar red.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "h5f36323egffecg4311g90b7gf89c9724dfae": ["The druid's blood runs hot and the girl suffered for it. Unacceptable.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "h434e71a0g54ebg4a10gb021g5d21b75cf948": ["It feels like the druids are trying to send a message.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "h757bb05ag8cceg4994g808bg4d59a7b02546": ["| I agree. I want option B (ShadowHeart Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "h1f608a96g851dg4109ga115gdd17acd279b8": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "h8d82ce29g99f1g4af4g9ad8g3220887b5aa2": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "h7c5989bagfdc4g4a61g83a0g4b9b54c4102a": ["| I agree. I want option B (Karlach Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "ha998f7d0g5502g4a20g80ddge05b91d301d3": ["| I agree. I want option B (Origin8 Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "h24266430g8226g4cb1g9658g03f2a236c81b": ["There's no excuse for Kagha visiting such violence upon a child.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "836a81f0-02ed-4f32-b55f-20372eb40e8b"], "h955417dfg86b0g45d6ga804ge92f9bda2bff": ["This was no accident. There's blood on Kagha's hands - enough to dye the Chionthar red.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "6de023a7-8fad-45a0-9639-269f04da99c1"], "hca6b47c4g7756g41c1g9c24g8420b92a2b68": ["The druid's blood runs hot and the girl suffered for it. Unacceptable.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "6de023a7-8fad-45a0-9639-269f04da99c1"], "h2befdcdbg07f3g4cd3g91dag07a8d0b69fdd": ["It feels to me like the druids are trying to send a message.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "6de023a7-8fad-45a0-9639-269f04da99c1"], "h856c3258ga186g4373gaff5g83232f3b3f5c": ["| I disagree. I want option B (ShadowHeart Variant) |", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "6de023a7-8fad-45a0-9639-269f04da99c1"], "hcac6d412g37f0g42dbg8417gb6f6b157a3e2": ["_", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Companions\\Reflection_Dialogs\\DEN_ShadowDruid_RD_KidDied.html", "6de023a7-8fad-45a