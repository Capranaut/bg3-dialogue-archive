{"h39dbc25fgfdddg4fdfgaf0bg566ddeab0d07": ["((*No - no. I feel the faerzress... fading...*))", "82af0858-d739-4c9d-84c8-5e6760e22e46", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "0c971e1d-37ef-173c-e69c-eb8b95205a3e"], "hff83aabcg273eg416aga5e2g5da699a05797": ["((*I cannot leave the Underdark...*))", "82af0858-d739-4c9d-84c8-5e6760e22e46", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "d686f51f-1af4-39dc-6343-2c8d4611ad6b"], "hca27db71g8736g4efbg892cg9d2396753a0e": ["*You recall the faerzress - the energy of the Underdark. The myconid might die if isolated from it.*", "NARRATOR", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "4f794b1c-8ec8-5eb0-245a-f59ebc2e1810"], "he2d71888g5703g49bbg9ea7gd0fc04c3e170": ["<i>Remain in the Underdark. This myconid is useful.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "5620ea64-11b7-4696-17fb-82f033b73b40"], "h7c1f48aeg579cg454cgabdbgcbf76f3572a1": ["<i>Dismiss the myconid and move forward.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "9b8cdd9a-111a-54f1-0b2a-403cbdb8a5bb"], "he0f58b76gc9f8g413cg93fbgc96d048d7923": ["((*I will refresh myself near Spaw's circle.*))", "82af0858-d739-4c9d-84c8-5e6760e22e46", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "fdc2326a-d9af-a8bc-48c3-b7770987996d"], "h47efb1c6gfbf0g4e52g9f0bgfb39d2915127": ["((*I will await near the shore.*))", "82af0858-d739-4c9d-84c8-5e6760e22e46", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "06a02b03-24fe-56f1-0c60-c62f4304a72b"], "h5d691190g9b0ag446bga353gcef4dcc62116": ["'Faerzruss'? I've heard the word, but don't know its meaning.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "77ea1165-6665-dbea-b238-207eacfefef7"], "hd2cf8632gf556g443eg83dcg8962e4688924": ["'Faerzruss'? What are you talking about?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "77ea1165-6665-dbea-b238-207eacfefef7"], "hc209e93cg1b6cg43f6g863bg80f5084319e3": ["((*It nourishes us all. The circles, the drow - we drink of its essence.*))", "82af0858-d739-4c9d-84c8-5e6760e22e46", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "56eb54ec-8e2f-8a33-6952-be2f1e5b4c17"], "h56d5fc79g9f3cg4ba7g8a71gd906fed729b6": ["((*Turn back. I am... weak...*))", "82af0858-d739-4c9d-84c8-5e6760e22e46", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "355c3ee8-d804-3af0-0564-f4adbee52748"], "h0bce1f06g581dg41ceg8152g0f56d138c1e7": ["*You feel it too: the Underdark's magical energy - the faerzress - slipping from your grasp.*", "NARRATOR", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "da15686a-970f-7d1c-c183-99a40e3bdd42"], "h6631e1ecgbb49g4df3g9750gefbaf9385ee2": ["((*Please... I cannot leave the Underdark...*))", "82af0858-d739-4c9d-84c8-5e6760e22e46", ".\\dialogs\\Act1\\Underdark\\UND_MyconidCircle_BroodingSovereign_Leave.html", "874c298d-6e16-76ac-770f-a182fbd268bc"]}