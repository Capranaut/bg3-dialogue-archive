_CRD_2.html", "910a15ed-b70b-a452-0a74-a5341377747e"], "ha8797e80g7ecfg4980g837agb37cfbbd6734": ["Strong. Fight! Win!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "bda8e2eb-96e8-16b7-43ea-04a743e886f8"], "h0338bba8g87dfg4a71g9f1cge0840b2317b3": ["Take on something closer to your own size next time.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "bbd79a87-33ef-7141-6d5f-6059d712f46b"], "h061de27ag6d03g4bf0gbb52gd6775686ec38": ["Too big... Wait! ", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "e21f2db7-8388-0965-d6f2-386b2c4aee24"], "h9b6ca0f2ge3b5g4a01g9389gf925043cfe60": ["Strong! Show you!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "b5c89495-ddd2-11d2-4fed-79e4e25e3da8"], "haca3711fgdbf2g4a5ag9b0eg6ee234abc52f": ["And? Did you kill any?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "62f913ae-2006-9e4e-d660-8dc0d63883ae"], "he2c51ef0g4039g411fgad78g818743aea756": ["Kill? No...", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "28700c73-7a90-950c-beab-504c60844bf5"], "hdbaa8742gcf5bg4eedg8bc2g76d0c277b4d7": ["Gods. Not even fully grown and you're already trouble.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "7947027d-b18d-18be-5cd7-4d0502eb3bdd"], "hacb529b9g9c7bg4ed0ga868g98642d7f40ec": ["Not trouble! Show you!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "60b4043e-fe3f-7f45-e931-072b4e36f15c"], "hd7166cd0g92c6g4776g9f4cg36a1db394c63": ["<i>Pet him.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "36e0f84c-5499-7823-89f6-7133b3009d0e"], "h76911f41g9758g43eag82adgde6d424f526b": ["Friend. Bite?", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "2ce62168-89ef-2fb7-806d-d62dce85a4a4"], "h774afa3fg71abg42f5g8007g4f1b211dcf5c": ["BITE!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "d71e3694-9895-0a2d-6a7f-557d9eaf9234"], "h31175c96g57e2g4039ga7c5g79433f12d262": ["Go on, then. You're all better.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "da711035-ca64-2d5b-9b57-8d6a641baba7"], "hda8d92efg872bg42bdga811g9ee397f22398": ["Come back. Strong. Show you!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "10522440-a619-3022-87da-b8eac1e564ff"], "h43f19142g0ae9g448bgae83gc0a808d13eee": ["Back! Hurt me!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "e92748e4-3b34-a54d-28e5-9a9835d523e6"], "h3a5d1688g40c5g4056g87fdg301aa4cde5e0": ["It's barely a scratch. You'll be fine.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "4ef9feb9-c537-100d-10bd-1c75a8aefb97"], "hc90a7024g0301g4610g82acg08b39c919c64": ["Good? Strong!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "c2415429-e89e-7fe9-fd0d-59247ef70794"], "h530e4de9ge72ag4ea5g92d4g18073272810c": ["Liar! Hurt me!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relationship_Dialogs\\CAMP_OwlbearCub_CRD_2.html", "39a96888-f312-4714-5829-d52baaff233a"], "hc114074agd4b5g4776g86d4ge6ba11e016d9": ["Run. Hide!", "c66b2865-6613-4372-b97a-e330c1d75d09", ".\\dialogs\\Camp\\Camp_Relati