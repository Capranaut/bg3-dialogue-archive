\\Swamp\\HAG_MurderousFrog_Frog.html", "35749e88-af39-9d86-47e1-5fc84d2f2c10"], "h093aa9c3ga628g4fd9gb582gc0baff604e0c": ["<i>Kill.</i>", "307a4abf-cecf-4755-88e1-a20b306fc3a8", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "ea3e536c-6de2-1c54-607d-f0b5dc118ff3"], "heda9dc06g987ag404ag8808g9d9be8f6f793": ["Perhaps I should just go. ", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "6ac78ef1-ddc8-5738-f4e9-e8967a141bf0"], "h2fbeeb95g0065g422eg8eebg3069eed39d89": ["<i>Green leaves. Shallow water. Green leaves. Shallow water. </i>", "307a4abf-cecf-4755-88e1-a20b306fc3a8", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "d9c5e7c5-9191-5a7c-829a-70fcb1cfa4a0"], "hd566143fg4c2dg4345g8ac6g2afdc24488ed": ["Something has tainted you. Is it magic? Poison?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "30b23fe0-9503-d752-497c-fb844808456f"], "h488018c5gc3d9g4f5bg957eg32ab6992717f": ["Careful. <i>Ethel.</i>", "307a4abf-cecf-4755-88e1-a20b306fc3a8", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "5a45d101-622f-e636-b2b6-4c91357ee315"], "h8374b6b2g31cfg4e15g8d0eg801d5aba1d5f": ["This isn't natural. What twisted you like this?", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "10cc854f-1ce9-0b3a-7bca-611c030c0e19"], "he6f4748eg9b39g4079gadc6g0e7be4d7fd54": ["<i>Leave.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "f76e473d-cf66-9725-e650-b31100e470e4"], "hc63800f7gd369g431dgb129gb2871feb9d40": ["You live here? It's beautiful.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "e9c194d0-cd28-0666-8aa0-abb4229b0ef2"], "heab54b37g6862g4a6cga86dgfab210211f93": ["No. Yes. ", "307a4abf-cecf-4755-88e1-a20b306fc3a8", ".\\dialogs\\Act1\\Swamp\\HAG_MurderousFrog_Frog.html", "0a071ed3-bd20-3fa2-b377-52d669aa761f"], "h