{"h29492cb4g1b63g4534g870agccc5b0752fec": ["*The spider appraises you hungrily.*", "NARRATOR", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "dd62e439-145a-c81a-2475-e06018f4db6d"], "h928bb8b0ga484g4c52gaac1g500a1c1e62c9": ["*Skree!*", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "b66a48d2-c42c-03b0-ad0d-cdcbd5662f95"], "hbbd0b4a2g4571g47c3gbd83gf44fecdd8469": ["<i>Hold up your hands to show you mean no harm.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "2d6587dc-8b38-b9e4-a421-67f3bd5becc3"], "ha6a12da3gc440g42b3g92b7gaf6c3cac03cc": ["*Skrrrr.*", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "a5c67c52-db6d-5cde-449b-291f5c5b0985"], "h3856e27eg400fg4386g89d5g48005de38d22": ["*Skreeeeeee!*", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "4de5cd1c-21a8-860d-6c16-3dda06c5b9f1"], "h3c796a4cg74cdg4262g92fagade77b01fe07": ["<i>Raise your hands, commanding it to let you pass.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "ac53189e-c99f-01e5-c9e6-4e7f54817032"], "he2d918f0gd1a0g4a6dg8f79gcfd1073d834b": ["<i>Attack.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "e603ded1-02fa-5d05-52a9-f80871e9163d"], "h23df68c3g4d54g4e46gaeb6g0b03d2f9fb4e": ["You are no goblin. Who are you? Answer me or die.", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "24f5cf3b-8c87-891c-7df1-32ec024dbfcd"], "hd9ae3307g1588g4f64g83c6g03d6375d17c0": ["Just a visitor. I mean you no harm.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "029f7a40-2526-f1bc-d0b6-524c0b4236a6"], "hbccbfa96g9663g44b3g9d83g9fd52faac2f4": ["This is my home. Do not stay long.", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "9c44fd17-415a-1f2b-a2f9-a4f12fcd628e"], "h4b771a66g378ag4447ga1fbg047453a7ce2d": ["You don't mean harm. I do.", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "26f3cf8b-d996-6ae5-9f47-2d7b1382559e"], "he6a033f9g6fd2g4184gaf5cg951802a76e20": ["I'm here to free you.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "f70b8501-2983-4fbc-62ed-fa37cec23249"], "h042d4bcfgf2feg48ceg80f3gf0ee6d01b8c9": ["My freedom will be the goblins' doom.", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "5953d5cd-bddc-f13e-f421-0a2c9fac2388"], "ha820473agab47g408dg8340g4766eb9e33ca": ["I won't leave. It's safe in here. But not for you.", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "27e8baac-9d35-0213-6de2-48bbecbf1389"], "h1508de62g4398g4d27ga9d9gb7ca129662ed": ["Just a visitor, young one. I mean you no harm.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "f158cb2c-6ac8-1f92-f5a5-3e49848a333b"], "h65e3f2ddg32fbg4970g975cg89a3f0646772": ["Child of Lolth, I'm here to free you.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "27e98b44-dc3b-71ff-6a45-157d24ed9ca3"], "h1c4f2df8g413cg4b69ga671g496c2dae007c": ["<i>Attack.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "525552d1-a707-7c39-6653-030fa4aba15c"], "h36e52bf5gb251g4befgb135gfc123ee1a286": ["*Skrrrr.*", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "161660b2-3488-9051-aff9-d3c54e136c94"], "hab7b14bcga433g4d31g88efg582be5922273": ["You are safe. We will not bite one another.", "03d2278d-f1fa-41ff-bdbe-03045725d990", ".\\dialogs\\Act1\\Goblin\\GOB_GiantSpider_Tiny.html", "b4d2379d-4767-31f2-bd75-af12808094b0"]}