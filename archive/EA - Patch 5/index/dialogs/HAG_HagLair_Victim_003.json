_003.html", "61f3ccee-a243-d493-f46f-2b5225629cd3"], "h25b92edeg1234g4772g8c19g4e1b8e9030c6": ["AH! Nononono - I'msorry. I - I - I - ", "4c1e4973-e9e8-458c-bd77-0a8b9ef7e3bf", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "1a78fe85-3bc6-daac-d533-6c9d6ed6df3f"], "h15158636g4c9dg45a9gb1d9g1a02e2b4fe15": ["<i>Silently step away.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "0dc697e4-d070-0d95-ae2f-23fb30f97691"], "h3b6c4b51g4f39g473eg80d7g9c3a7b1dae3d": ["Mind... flayer... ", "4c1e4973-e9e8-458c-bd77-0a8b9ef7e3bf", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "4ccf0785-0683-729f-08e6-a2ce98cebce6"], "h245724c3g92eag4abfg8833gcd5e234f77d0": ["Your vision is false. I would never become a <i>ghaik</i>.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "0777851a-e592-924d-77da-d36d88692ba0"], "h515cac36g8503g497fg9df2gdc6f3af9ef50": ["Leave me, leavemealone! Please!", "4c1e4973-e9e8-458c-bd77-0a8b9ef7e3bf", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "3d7fb943-8cfd-7de6-e1dc-d9dcf1ef1969"], "h5d9756ddg31f9g4f06gbc4cgfa8450ade5fc": ["You're safe with me, I swear.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "ff396593-5eb1-c17e-9a6c-467de98a5e3d"], "h4e86268dgd942g4345g93b2g33201e58d21a": ["NO! No. Monster! ", "4c1e4973-e9e8-458c-bd77-0a8b9ef7e3bf", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "86c1ff24-3129-9379-c847-48d4078bc89b"], "h8c543944gf1f0g4d28gb1f1g99d7a02ac4a2": ["Every time you open your mouth, it gets a little more tempting.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "1ab16c31-1f60-cbd0-7261-d8abaae263ec"], "h75ed82aag5c00g42bag9fd9g828ea4b01145": ["Not everyone looks like you do, elf. It's shocking, I know.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "6f69592a-6df4-560d-e04c-eca936bb6b88"], "h58a5f607g09dcg4192gbfcbg13ee33b7f1ed": ["ARGH. NO. Stop. Tricktricktrick. Monster. MONSTER. ", "4c1e4973-e9e8-458c-bd77-0a8b9ef7e3bf", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "5d27e59c-3349-2847-4545-73c7aba1853d"], "hc7cbf30ag437cg4227g9b92geaa82cf9864d": ["Even I know screaming in someone's face like this is not polite.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "2a22f9d0-82d5-dee6-45d5-264620962af8"], "h9b0c34ccgd5f5g428cg9ac7gdf9936b316a6": ["My people do not take orders from your kind.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "719cdeae-39d8-c979-886b-593cd07a777f"], "h4db65812gf5c4g4027g8197gdfae071d9332": ["Not drow. Neverdrow. Monster. MONSTER.", "4c1e4973-e9e8-458c-bd77-0a8b9ef7e3bf", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "f1830330-c701-597e-2595-91e0ce4f8deb"], "h433ee032g9655g4102gb596g4e7ef435e328": ["Be calm. I am not sworn to Lolth. You need not fear me.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "7bf379ac-06b2-7d11-e60a-49faf8ef12b7"], "h7b1192d8gf067g4a0eg9ea9g63d41db4b323": ["<i>Speak in your mother tongue - try to calm him.</i>", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "76c477cf-3910-c958-c528-ca3dbd082c64"], "h48bb4fa7g3995g495ag8adag157f64bfc08c": ["Hey! Look at me.", "e0d1ff71-04a8-4340-ae64-9684d846eb83", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "95d99b82-eaf4-5615-58ea-ebc611ce004c"], "hd563d121gb272g4b11g90d3g0ece60cacd0f": ["No. NO. Can'tstop. Can't - ", "4c1e4973-e9e8-458c-bd77-0a8b9ef7e3bf", ".\\dialogs\\Act1\\HagLair\\HAG_HagLair_Victim_003.html", "b05d552d-1bd7-839f-9887-bb338c0029da"], "h9cb40832g5204g4928ga1bfg15ada5e98734": ["What are you doing? Get out of here. ", "e0d1ff71-04a8-4340-ae64-9684d846