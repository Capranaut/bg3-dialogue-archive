				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "Players find a humanoid strapped to an operation chamber, his skull opened to reveal his brain. When starting a dialogue with the humanoid, they will hear a strange voice in their mind. Through investigation they can learn this to be an intellect devourer trapped in the man's skull. The player can assist in liberating the intellect devourer and gain it as a follower for the duration of the tutorial or kill it."
				}
