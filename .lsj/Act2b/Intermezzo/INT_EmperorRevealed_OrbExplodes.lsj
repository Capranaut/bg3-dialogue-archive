												},
												"val": {
													"type": 23,
													"value": "[WI][Custom/Construction/Reuse]  Gith monks running towards the skull. (Construction) A couple acrobatic/parkour tricks to bring out the intensity and the drama. Navigating through the terrain of Astal Plane."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "Player observes from their arrival point in the Astral Plane, looking across toward the globe of domination, which is a few screens away, across a couple of floating platforms. The globe of domination begins to destabilise - it's about to shatter. "
												}
											},
