													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "Stelmane conducting business with a merchant. The merchant eyes the door to her office warily. Through a gap in the door, we see the vague outline of the Emperor like an unidentified mob boss sitting in its chair. Eyes faintly glowing, shape indiscernible. We see the merchant's unease. \r\n"
												}
											},
