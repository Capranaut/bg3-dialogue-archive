										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[LILI] Emperor thrown to the ground, looks up and stare at the elder brain"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "Shot from Emperor’s POV of chains and magic lashing, binding him. Blurring in and out as if fading in and out of consciousness. Next conscious moment: staring at the stars through bars on the back of some sort of horsecart. Next conscious moment: the mind flayer colony coming into view. Mind flayers turn to stare. Next conscious moment: the elder brain, and beside it, Gortash. \r\n"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicObjects"
												},
												"val": {
