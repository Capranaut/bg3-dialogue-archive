			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "loadlevel WLD_Main_A\r\noe readyattackonden\r\ngoto 297.75, 35.51, -25.25\r\nKill True Soul Gut\r\n1\r\nKill Dror Ragzlin\r\noe debugbook > go to region > act1 > grove\r\nBlow war horn to trigger raid\r\nKill Minthara\r\ngoto 399.91, 33.02, -29.76\r\nkill combat > Speak to Halsin / or halsin should have escaped\r\ngo back to grove to witness zevlor speech + halsins arrival\r\ngo to camp + long rest\r\ndialog should trigger after rest"
				},
