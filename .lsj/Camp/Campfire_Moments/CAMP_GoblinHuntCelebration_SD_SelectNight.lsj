				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "When player chooses to sleep after goblin hunt celebration, this narration dialogue occurs. If Minthara does not have a partner, she will attempt to talk with an avatar who hasn't refused her directly.\r\n\r\nNote: the player might be meeting up with Lae'zel or Astarion for a second time after sleeping with them before in the past.\r\nThe reflection moments are for characters who the player may have already done the romance for, who don't have a romance tied to the overnight (only Wyll), or who don't have a second romance scene available overnight if you did the first (anyone other than Laezel and Astarion)."
				}
			}
