								"editorData": [
									{
										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[GERRY] MizoraEnters: The player enters camp. Wyll joins player, fully in view. A diabolical circle draws itself onto the ground in front of you and Wyll, and Mizora in devil form rises from it, turns and nobly poses."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "The player enters the camp, Wyll waiting at a side, fully in view. A diabolical circle draws itself onto the ground in front of you and Wyll, shocked/surprise, and Mizora in devil form rises from it, maybe can have a turn and a noble pose at the end.\r\n"
												}
											},
											{
