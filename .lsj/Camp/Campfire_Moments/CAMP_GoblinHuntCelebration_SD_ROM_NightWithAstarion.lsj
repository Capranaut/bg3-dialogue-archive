				"nextNodeId": {
					"type": 5,
					"value": 850
				},
				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "After the goblin hunt celebration party (whether the player helped the goblins or the tieflings), Astarion has made arrangements to get intimate with the player at night. For Astarion, this is a game of power - one he's played many times before in the taverns of Baldur's Gate, trying to lure people back to his master. He's an old hand at seduction, very self-assured at first, but the player might not go along with the script he expects them to follow. The next morning, the player wakes to see Astarion standing and getting dressed. They catch a glimpse of scars on his back - a sore point. The scars were carved into him by his old master. As far as Astarion knows, they're a poem, but he's never been able to read it (can't look in a mirror, after all)."
				}
			}
		}
	}
}