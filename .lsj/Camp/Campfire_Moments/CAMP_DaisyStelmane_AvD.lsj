													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "The player wakes up in the dream field. Shot of the Emperor is sitting with its back to you on a bench, alone, looking unusually pensive and morose against the backdrop of the astral plane - the globe of domination visible in the distance. All is quiet now in contrast to the battles we previously saw here. The player approaches."
												}
											},
