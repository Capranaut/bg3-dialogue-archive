												},
												"val": {
													"type": 23,
													"value": "[LILI] *REUSE* [Player] CINE_Slow_Walk_to_Stop, [Emperor] Seated looking into the distance Idle"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
