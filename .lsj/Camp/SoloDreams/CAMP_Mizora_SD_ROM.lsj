												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[GERRY] The player reaches out to the flames, hesitently letting them dance around their fingers. Then they cup their hand bringing some of the flame back, close to their chest."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
