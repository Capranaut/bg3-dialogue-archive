												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[GERRY] The player's flame glows black for a moment, then glows back to bright red at the end of the line., , The player extends both arms out toward the flames, palms down. Their eyes close as they connect with Mizora's hellish offerings., , She watches as the pleasure rides out the sensations., , , Long idle for dialogue, , N54, N166, and N225 (REUSE this asset for the different flame colours.)"
												}
											},
