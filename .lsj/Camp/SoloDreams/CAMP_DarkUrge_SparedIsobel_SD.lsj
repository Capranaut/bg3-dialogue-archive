																	"value": "034eca42-bfcc-4fd3-8224-c58d86942b78"
																},
																"TagText": {
																	"handle": "h40f5a64ag76b1g4644gb365g4c259726c971",
																	"value": "Few have an unblemished history. You must better yourself, not condemn yourself.",
