												"TagTexts": [
													{
														"TagText": [
															{
																"LineId": {
																	"type": 22,
																	"value": "8832d8fa-dfb3-4335-b684-08d0429797f0"
																},
																"TagText": {
																	"handle": "h5052d6a1g99d0g4e97ga8a6g924486421269",
																	"value": "It's bad. I won't say it isn't. But... I've done worse. Powers beyond our control picked us to do their dirty work - that isn't our fault.",
