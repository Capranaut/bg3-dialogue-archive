										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[PLYR] raises their dagger, almost unconsciously. The first cut is through their vocal chord, but the sputtering, choking gasps are still audible, so the PLYR stifles them with a hand over the mouth. As the Urge grows within, the PLYR really starts getting into it, stabbing over and over and over. The companion is flailing impotently until they give one final, pathetic push and fade away. Idle here.<CodyM>"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
