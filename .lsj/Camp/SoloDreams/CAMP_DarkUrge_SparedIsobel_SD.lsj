												"TagTexts": [
													{
														"TagText": [
															{
																"LineId": {
																	"type": 22,
																	"value": "8aab5a14-6c2d-4cf9-8881-847b0d0763d1"
																},
																"TagText": {
																	"handle": "hcfaed499g0adeg4a6dgb45eg5e15bb1a53a1",
																	"value": "You are not the before. You are the now, you are the later. If your past is so diseased, let it wither and plant something new.",
