			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "Go to Wyrm's Crossing region and speak with Yenna at the very start. After this dialog ends, go to camp and she will be waiting for you. Speak to her in camp to trigger this dialog.\r\n\r\nDebug commands\r\n- YennaVisitCamp (send Yenna to visit camp, without having to speak to her in WYR)\r\n- YennaMovedToCamp (set up Yenna in camp as if she's already been invited to stay)"
				},
