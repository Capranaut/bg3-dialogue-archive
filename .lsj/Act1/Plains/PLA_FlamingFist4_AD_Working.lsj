				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "A Flaming Fist trying to force their way inside of a burning inn. They can hear someone inside - they believe it might be a Duke of Baldur's Gate, who they were sent to guard on his way to Elturel. Instead, they found the inn burning, its staff and guests murdered by goblins and drow in the night.\n\nOnce inside, they set about trying to clear rubble to reach someone trapped within."
				}
			}
