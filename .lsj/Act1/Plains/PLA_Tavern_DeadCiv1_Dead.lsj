				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "The Cult of the Absolute has ransacked the inn at Waukeen's Rest and kidnapped Duke Stelmane of Baldur's Gate. The player arrives after the carnage, finding corpses strewn about. The player casts 'Speak with Dead' on one of these corpses - a civilian that was caught in the middle. She stopped in Wakeen's Rest with her husband and daughter in the middle of their journey to Waterdeep for a wedding. She watched her family butchered by goblins before being killed herself."
				}
			}
