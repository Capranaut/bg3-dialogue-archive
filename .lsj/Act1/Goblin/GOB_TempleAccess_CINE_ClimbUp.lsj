			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "Repro steps:\r\n1. Start the game.\r\n2. loadlevel WLD_Main_A\r\n3. goto 153.71, 64.79, -263.72\r\n4. Click on the ladder - will launch the cinematic.\r\n5. ReCon: \"oe und_cine_reset\" -  this will allow to see the cinematic again when clicking on the ladder (by default the game shows it only once)"
				},
