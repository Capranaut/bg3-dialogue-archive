			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "Retro steps:\r\n1. Start the game.\r\n2. loadlevel WLD_Main_A\r\n3. Access debug book > Set quest flags & options > act 1 > Underdark > Duergar camp > Get unfortunate gnome\r\n4. goto 0.677; 41.554; 419.55\r\n5. Talk to Barcus"
				},
