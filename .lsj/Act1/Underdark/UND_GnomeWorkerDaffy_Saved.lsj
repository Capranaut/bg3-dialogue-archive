			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "Repro steps:\r\n1. Start the game.\r\n2. loadlevel WLD_Main_A\r\n3. goto -633.35, 14.65, 316.97\r\n4. Ctrl + Shift + K the rubble blocking Nere's escape.\r\n5. Nere dialogue starts - Pick the dialogue hostile to Nere. 2. Enough Nere. and 2. Lay a finger on me etc.\r\n6. killcombat the hostile Duergars.\r\n7. Speak to Beldoran, a Gnome in a bowl cut and red shirt, at -633.75, 14.65, 309.25\r\n8. Goto 88.39, 49.92, -93.81\r\n9. Speak to Daffy. "
				},
