										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "Pulls eyeball from socket, waves hand around it and then jams it back into the players head <AaronH>, CDavis: [Hag] Raises her arm, finger straightens to a point as if a blade. Drives her finger/nail into the [Players] eye and after a beat yanks it back out. The players eye is on the nail, and then she either - kisses it gently or wave her hand over it (whatever is easier), then jams it back into the [Players] empty socket."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "Hag raises her forearm, fingers straightened to a point as if a blade and drives her hand towards the player's face. Rips her hand back, shot of the eye on her nail (maybe?) and then she either - kisses it gently or wave her hand over it (whatever is easier) and then jams it back into the player's head. "
												}
											},
											{
												"key": {
													"type": 22,
