				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "The player speaks to a deep gnome after freeing him from some goblins, who'd had him tied to the sail of a windmill. The player discovers that the deep gnome travelled to the region as he learned his old friend is in danger. By way of thanks, he provides the player with the means to craft smokepowder, an explosive item. He then leaves for the Underdark in search of his friend. There, the player may encounter him again."
				}
			}
