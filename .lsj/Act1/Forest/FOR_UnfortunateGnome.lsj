			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "repro steps:\r\n1. Start the game.\r\n2. loadlevel WLD_Main_A\r\n3. goto 0.60, 36.99, 424.64\r\n4. Resolve the dialog with goblin or kill everyone.\r\n5. go to the lever in the windmill and choose the \"brake\" one.\r\n6. Talk to Barcus and choose to free him."
				},
