                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "8e13c8e7-8047-4fe1-a9cb-33cfaa82b593"},
                                                "OldText" : {
                                                   "handle" : "h1282ae95g3ee4g4ab8gac42g362da957509f",
                                                   "type" : 28, "value" : "If we <i>do </i>start to turn, I'd prefer a method with a little more flair than poison. Is self-immolation totally passé?",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h8f4decb1g4c94g4699ga879g94a30c6ee570",
                                                   "type" : 28, "value" : "But what were the grubby little beasts after? This place doesn't look like much.",
                                                   "version" : 2
