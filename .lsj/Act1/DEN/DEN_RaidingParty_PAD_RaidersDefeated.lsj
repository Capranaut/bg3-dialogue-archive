                                                "OldText" : {
                                                   "handle" : "h809d315bgb3ebg47eegb4cegb2355027ef2c",
                                                   "type" : 28, "value" : "Pretty bottle, but I wouldn't take wyvern poison, even if we do begin to turn.",
