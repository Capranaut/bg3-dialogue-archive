                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "73454de9-aa94-452f-9816-61ac7fe241d8"},
                                                "OldText" : {
                                                   "handle" : "he267111cg8eafg4ee0g8ce6gf780c4b5dadb",
                                                   "type" : 28, "value" : "Hear, hear. If you turn, I'd rather slit that pretty neck of yours myself, anyway.",
                                                   "version" : 1
