                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "04c94a88-8ee4-4439-b050-dc40d56e8c15"},
                                                "OldText" : {
                                                   "handle" : "hffd1b2e5gd234g442cg825dg441b5764cb08",
                                                   "type" : 28, "value" : "If we begin to turn, we will die by the blade - not like cowards suckling from a noxious teat.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "hcbeceba3gde63g41adga69ag3ed07b933589",
                                                   "type" : 28, "value" : "A brazen attack, for such lowly creatures. They must have been seeking something - or someone.",
                                                   "version" : 3
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
