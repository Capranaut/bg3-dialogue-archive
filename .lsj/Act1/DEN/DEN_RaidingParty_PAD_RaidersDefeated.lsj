                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "db95e0ed-7128-4847-893d-d0820a023c2a"},
                                                "OldText" : {
                                                   "handle" : "hb94b1dd7g39dbg486dg8deega4ebf229a75b",
                                                   "type" : 28, "value" : "Oh, I don't know. I can think of worse deaths than toasting to you all with a wyvern sour.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h04cdb5d5gcce3g4602gba6dg2e75b3917c9c",
                                                   "type" : 28, "value" : "A taste of goblins to come, I fear. There must be a horde nearby.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
