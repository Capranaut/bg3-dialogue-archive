                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "d04797e8-c618-4140-8b0b-db5fd8c42496"},
                                                "OldText" : {
                                                   "handle" : "h495f3cb9g8bf6g4442gadc4gc25a291b6593",
                                                   "type" : 28, "value" : "Better to have more options than fewer. If you start sprouting tentacles, I'll pour it down your throat myself.",
