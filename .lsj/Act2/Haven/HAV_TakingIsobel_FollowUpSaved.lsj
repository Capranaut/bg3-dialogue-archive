								"editorData": [
									{
										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "*REUSE* [Isobel] casts magic exists in HAV_TakingIsobel_BriefInRoom, no name created yet <Greg>"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "|Casts 'Protection from Good and Evil', but modified with Selunite (moon) magic to protect against the Shadowcurse specifically. Isobel can use the planned animations for this spell cinematically, or something bespoke as best fits the scene.\r\n\r\nWe see every party member  take on a moon-like effect as a result of being targeted with the spell, which then fades as though absorbed by each of them. This gives them a special in-game status to protect them from the curse|"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicObjects"
												},
												"val": {
													"type": 23,
													"value": ""
												}
											},
											{
												"key": {
