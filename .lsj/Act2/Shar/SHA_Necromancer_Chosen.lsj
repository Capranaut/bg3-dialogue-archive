																	"value": "2a482127-72d0-4b86-94cf-f6be5337d227"
																},
																"TagText": {
																	"handle": "h0e622502g9ddcg4bafg9c41gbdf5e50a4637",
																	"value": "Hatched, you say? That's novel, I'll admit, but still limiting. There's always room for improvement when it comes to the flesh.",
																	"type": 28,
