								"editorData": [
									{
										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[KAYLEIGH] Stunned she strains to see out the window - She flinches as she suddenly hears screams echo inside. She turns to the door behind her focusing on the sound of combat that grows closer and reaches for a weapon (sword)"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "Stunned, lit only by candlelight, she strains to see out the window - then flinches as screams echo inside the inn. She turns to the door as the sound of combat grows closer. She's already reaching for a weapon when the candles go out - and in darkness we hear her door crashing open. Wide shot from the far side of Last Light's bridge: all sources of light flicker and die as the darkness closes in. The screaming goes on."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicObjects"
												},
												"val": {
