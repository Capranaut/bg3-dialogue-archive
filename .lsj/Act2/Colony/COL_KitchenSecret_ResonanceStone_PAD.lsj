			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "This dialog is triggered once per user and nearby players upon gaining or losing the Eldritch Pleasure buff (determined by a flag) as bestowed by the aura of the Resonance Stone in the secret sideroom of the kitchen/dissection room on the lower floor of the Colony. The Resonance Stone can be picked up and may give the Eldritch Pleasure buff to those nearby the player carrying the stone. The removal dialog will only trigger upon losing the buff while inside a trigger near the Colony kitchen."
				},
				"defaultAttitudes": [
