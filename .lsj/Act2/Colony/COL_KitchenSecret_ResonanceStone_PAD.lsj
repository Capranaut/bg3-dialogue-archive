				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "The players react to gaining or losing the \"Eldritch Pleasure\" status effect from the Resonance Stone in the secret sideroom of the Colony kitchen/dissection room. This status is applied or removed upon gaining the \"Eldritch Pleasure\" buff bestowed by the aura effect of the Resonance Stone, and will only play once per user and nearby player. The removal dialog will only trigger upon losing the buff while inside a trigger near the Colony kitchen, as to avoid it playing unexpectedly during later parts of the game."
				}
			}
		}
