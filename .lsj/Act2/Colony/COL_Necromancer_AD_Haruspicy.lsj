				"needLayout": {
					"type": 19,
					"value": 0
				},
				"nextNodeId": {
					"type": 5,
					"value": 9
				},
				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "The necromancer is standing over a bowl of blood and bone, conducting a ritual to see the future. This will trigger in the Necromancer's idle behavior if you entered through the main entrance while he is still alive OR after all zombies have been revived in the post-Audience combat and the players are still in the cages.\r\n\r\nFor help with Latin, contact either Tom Ryckeboer or Ilya Voulis."
				}
			}
		}
