			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "- Load GustavDev/SCL_Main_A\r\n\r\nAudience Route:\r\n- Use ReCon command \"oe Necromancer_Audience\"\r\n- Stay inside the cages.\r\n- Wait for the Necromancer's turn in combat, he will send a zombie to light the candles.\r\n- Wait for the Necromancer's next turn - he will start resurrecting the nearby NPCs and turn them into zombies. \r\n- Wait until all zombies are resurrected - he will start this chant on his next turn.\r\n\r\nOther side: \r\n- Use ReCon command \"oe Necromancer_Assault\"\r\n- Balthazar will be chanting this when you approach him in the chamber."
				},
				"defaultAttitudes": [
					{
						"data": [
							{
								"key": {
									"type": 22,
									"value": "0"
								},
