			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "In the lower floor of the Mind Flayer Colony, find your way to the Cleansing Room. In here, there is a large chute leading in from the (inaccessible) Oubliette on the other side. Place one player character beneath the corpse chute/tentacle, and let another press the button to open the chute. Blood will spurt out and the player getting sprayed will react to this."
				},
				"defaultAttitudes": [
					{
						"data": [
							{
								"key": {
									"type": 22,
									"value": "0"
								},
								"val": {
									"type": 23,
									"value": "Neutral"
								}
							}
