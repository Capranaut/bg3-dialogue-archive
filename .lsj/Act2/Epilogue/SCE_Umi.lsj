			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "1. Run oe SCE_TieflingFollowUp_SetFlags\r\n2. Run:\r\noe SCE_TieflingFollowUp_AllTieflings\r\n-or-\r\noe SCE_TieflingFollowUp_NoCerys\r\n-or-\r\noe SCE_TieflingFollowUp_NoAlfira\r\n3. Run oe SCE_SetupDebrief\r\n4. Click through the Jaheira/Florrick dialogue\r\n5. teleport S_Den_Trainee_001\r\n\r\nAdd eyepatch with: oe SCE_TieflingFollowUp_AddEyepatch"
				},
