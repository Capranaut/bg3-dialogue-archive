										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[Yonas] is tumbled down the incline (SCL_HarperScouts_Yonas_Fall).  After [Meygan] calls out (check if V.O anim is appropriate), *DUPE* [Harpers] move in closer together, facing the creature (SCENE_SCL_HarperScouts_React_toCreature) <LoganP>"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "Yonas notices something behind him and twists to face this new threat, but it's already close and reaching for him. He stumbles to the side, tripping over a root as he tries to dodge a reaching claw, and tumbles down the incline, disappearing into the darkness. [The reaching claw can be cut for cinematic simplicity, the core of it is: \"Yonas sees thing, gets spooked, falls down the incline and out of sight.]"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicObjects"
												},
