								"constructor": {
									"type": 22,
									"value": "TagGreeting"
								},
								"editorData": [
									{
										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[HarperScout]s are walking with weapons and torches drawn. They react and step back as [PLYR] lands. The Harpers reform with weapons aimed at PLYR., Can use SCENE_SCL_HarperScouts_DropLand_PLYR & *DUPE* SCENE_SCL_HarperScouts_WalkStartled_toIdle <LoganP>"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "The player has leroy jenkins'd into the scene by jumping off a high precipice from above, landing amidst the Harpers, who jump back in surprise, and regroup away from the player, so that the player is in a more 'standard' dialogue position at the end of the node. Lassandra gathers her wits immediately after her intiial shock and addresses the Harpers, afraid they've leapt into the darkness. Points weapon at player ."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicObjects"
												},
												"val": {
													"type": 23,
