												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "In the darkness nearby, burning torches grow near, silhouetting a small knot of armed figures moving in a tight huddle. The player moves closer. A dead branch snaps underfoot, startling one of the figures - Lassandra, a wide-eyed young woman wearing half-plate under a blue cloak. She brandishes a torch and sword."
												}
											},
