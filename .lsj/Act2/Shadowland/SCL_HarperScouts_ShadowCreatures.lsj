												},
												"val": {
													"type": 23,
													"value": "[HarperScouts] walking (SCENE_SCL_HarperScouts_Walk_toStartled_toIdle). [PLYR] stops as they snap a stick. <LoganP>"
												}
											},
											{
												"key": {
													"type": 22,
