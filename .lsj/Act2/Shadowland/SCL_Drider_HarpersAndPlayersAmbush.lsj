												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "The HALF-ORC shoots you a dirty look, but follows the DRIDER into the darkness, along with the other cultists. There is silence for a beat before screams start to pierce the air. There is sound of a brief battle. \r\n\r\nTo account for Vez being dead or alive we will rely on a Show Actor key in Node N858."
												}
											},
											{
												"key": {
													"type": 22,
