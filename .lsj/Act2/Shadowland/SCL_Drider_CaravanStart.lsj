											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[Goblin] picks up bone and throw., [Hyena] chase after the bone and got drag away by shadowy tendrils in the dark. <Choicelyn>"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "The goblin picks up a bone, gets the attention of a nearby hyena, and then throws the bone into the shadows. The hyena chases after it, disappearing into the dark. In the darkness, shadowy tendrils grab the animal. It's dragged  away yelping, until it's silenced with a *crunch*."
												}
											},
