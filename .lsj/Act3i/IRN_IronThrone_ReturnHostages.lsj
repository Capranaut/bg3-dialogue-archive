			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "Talk to S_IRN_EscapingHostage_614ceeec-24a5-4491-98b3-a83ab235f158 after successfully escaping the IronThrone.\r\n\r\nIf he died, talk to any other surviving hostage."
				},
