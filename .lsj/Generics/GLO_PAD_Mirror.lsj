                                                "LineId" : {"type" : 22, "value" : "2fa6cb09-b223-424c-8137-1ca1f9068ec8"},
                                                "OldText" : {
                                                   "handle" : "hddd33be9g82c5g4852gb8fcg757acf8f1650",
                                                   "type" : 28, "value" : "Bah! Boo has pooped truer diamonds than these.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h3f786240ge447g4976g9342g2441adf6430f",
                                                   "type" : 28, "value" : "Bounce light all you wish, little mirror. Minsc will only bounce it back!",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             },
                                             {
                                                "LineId" : {"type" : 22, "value" : "7e12a835-1635-4f1f-9b8c-c472df72deac"},
                                                "OldText" : {
                                                   "handle" : "h382fb3b9gf42ag40f3g9daege2e3806693ed",
                                                   "type" : 28, "value" : "Hah! Minsc will not fall for this fool's gold. Not for a sixth time.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h67b10194g3b4ag46f5g94eag34cc239539d8",
                                                   "type" : 28, "value" : "Boo, Minsc has something in his teeth. Would you mind...?",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             },
                                             {
                                                "LineId" : {"type" : 22, "value" : "288f17d5-a460-441e-b5ef-a4e16b2ee0d9"},
                                                "OldText" : {
                                                   "handle" : "hd4bd5dcag4260g4dfegae0bgbe84a97cbf9a",
                                                   "type" : 28, "value" : "A shiny shell with nothing inside. Minsc has known many wizards just the same.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "hc9027573gea63g4f41ga297g377b4d6c0725",
                                                   "type" : 28, "value" : "Perhaps I should paint the rest of my skull. What say you, Boo?",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 }
                              ]
