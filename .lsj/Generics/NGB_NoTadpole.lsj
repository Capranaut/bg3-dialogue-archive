																"LineId": {
																	"type": 22,
																	"value": "411934ae-e50a-4d54-854c-2b28ec029013"
																},
																"TagText": {
																	"handle": "h00c332dfgb685g4ff7g9e95g6e5b8f08adfc",
																	"value": "*Your overtures are met with disdain - perhaps if you had a parasite swimming in your skull?*",
																	"type": 28,
																	"version": 2
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "8ad3ce1f-c29e-4c99-aade-617cd8c70b62"
																},
																"TagText": {
																	"handle": "he36386ecg0b90g4a4cga7f5g1eb3a1823263",
																	"value": "*All the charm in the realms won't do you any favours. A tadpole in your brain, however...*",
																	"type": 28,
																	"version": 2
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "ad14ce1b-45b2-4769-b7b4-583ff6671357"
																},
																"TagText": {
																	"handle": "h51448148g660cg4e24g88a6g6a8b3cb667d0",
																	"value": "*Without an illithid parasite buried in your brain, your words have no weight here.* ",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
