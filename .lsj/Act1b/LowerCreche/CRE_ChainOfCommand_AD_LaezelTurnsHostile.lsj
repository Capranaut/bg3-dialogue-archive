			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "Load up CRE_Main_A\r\nMake sure you have Laezel with you.\r\nGo to 1392; -2; -780 and enter the captain's office and get through the dialog\r\ngo to 1357; -7; -689\r\nenter the security office\r\ntalk to the inquisitor, and show him the artifact\r\ntalk to Vlaakith and tell her you won't do it\r\nLaezel should have left the party and is waiting for you to enter the Astral Prism\r\nLeave the security office - Lae'zel will go hostile, and trigger this AD.\r\n\r\n"
				},
