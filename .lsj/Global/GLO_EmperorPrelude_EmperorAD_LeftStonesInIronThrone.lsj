				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "The player dropped one or more of theNetherstones in Iron Throne and left before picking them up. The Emperor is not very pleased with the player and tells them to search the beach in hopes of finding them. Depending on the state of the booster Sahuagin Attack, the stones will be on one of the attacking Sahuagin, the fishmongers inventory, or in a dead fish that choked on them and washed ashore."
				}
			}
