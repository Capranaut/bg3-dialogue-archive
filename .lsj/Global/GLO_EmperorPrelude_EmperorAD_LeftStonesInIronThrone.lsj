				"HowToTrigger": {
					"type": 23,
					"value": "Go to Iron Throne\r\nDebug add the stones (example, oe glo_emperorprelude_gortash)\r\nDrop one or more stones\r\nLeave Iron Throne\r\nWait for AD to trigger"
				},
