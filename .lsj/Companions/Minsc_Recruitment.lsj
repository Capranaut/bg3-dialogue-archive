													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "Minsc transfers Boo to his shoulder and strikes a pose, declaiming heroically - then breaks down giggling when Boo crawls inside his armour. \r\n\r\nPuts the Hamster on his right shoulder (collar bone level) with his left hand, let Boo crawl on his shoulder and in his armour and strikes a pose, then laugh"
												}
											},
