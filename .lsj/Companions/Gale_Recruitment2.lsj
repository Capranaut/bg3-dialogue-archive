												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "(Cine) You reach out to touch the sigil. When you touch it, sparks fly, and you quickly retract your hand in pain, like accidentally touching a red-hot pan."
												}
