										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[ChristianD] Gale's arm movement is screaming for help as his hand is being pulled back in by the sigil. The PLYR rushes forward to reach for the hand but it's too late as Gale's arm completely dissapears into the sigil's sparkles."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "(Cine) The hand disappears into the sparkles and the sigil becomes dormant. A cry of 'I'll perish!' echoes several times, sounding increasingly far away, like an echo. Then silence."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicObjects"
												},
