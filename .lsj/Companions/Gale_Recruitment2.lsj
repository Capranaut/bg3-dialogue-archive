												},
												"val": {
													"type": 23,
													"value": "[ChristianD] Player starts with StandL steps forward to touch the sigil. As soon as the PLYR touches sigil, it sparks and the PLYR immediately retracts their hand in pain."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
