												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "We fade in on a forest clearing, on a moonlit night. A young half-elf girl pushing her off the forest floor, groaning. She looks around, fearful. SHADOWHEART, maybe eight years old. Black hair pulled back from her face. Across her cheek and the bridge of her nose a branch has opened up a fresh cut. She raises her hand to it with a wince.\r\n"
												}
											},
