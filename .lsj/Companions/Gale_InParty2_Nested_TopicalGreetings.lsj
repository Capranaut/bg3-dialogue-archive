																},
																"TagText": {
																	"handle": "h1ee30b94gbb1dg483agbc78gba336cc677ff",
																	"value": "Trust me when I say you're better off living unshaded by Shar's influence. Such a goddess would take everything from you, and still demand more.",
																	"type": 28,
																	"version": 2
																},
