																	"type": 22,
																	"value": "3b270392-f98d-4cb0-8891-de8c80535b05"
																},
																"TagText": {
																	"handle": "h1b5c1463g7c8bg4309ga7dfgb1e64f7659f6",
																	"value": "You can learn a lot about people when you understand the manner of their upbringing. Our time here will shed new light on your little quirks, I'm quite sure.",
