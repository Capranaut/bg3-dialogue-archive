											{
												"key": {
													"type": 22,
													"value": "NodeContext"
												},
												"val": {
													"type": 23,
													"value": "This scene is after her big dark night of the soul monologue after killing Gortash. She leaves to go to camp and be alone for a bit. When the player returns to camp, she's here, having a moment to herself. She's still raw, but is glad to see the player. If I had my way I'd have her seated for this, but we can't do it budget-wise. Maybe another way to get that sadness/ vulnerability across, like crossed arms, hand to chin, that kind of thing? I'll leave it with ye!"
												}
											},
