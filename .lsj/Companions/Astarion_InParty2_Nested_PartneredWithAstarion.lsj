												"TagTexts": [
													{
														"TagText": [
															{
																"LineId": {
																	"type": 22,
																	"value": "bd3e127f-96e7-4370-84e6-f345e20ea869"
																},
																"TagText": {
																	"handle": "h0d45930dge063g4d1bg861ega2540adb8d08",
																	"value": "<i>Aeterna amantes.</i> Lovers forever, until the world falls down.",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "315488fd-3d07-4932-a846-1f4c03318eb9"
																},
																"TagText": {
																	"handle": "hfed5dca5gba64g4e0cg90a5g82434f533b81",
																	"value": "We are sovereigns. My sole endeavour now is to make this world yours and mine alone.",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "73d2d46e-0850-402b-9afd-f13f5fbbbd8a"
																},
																"TagText": {
																	"handle": "h8626b7b9g805ag4b7egaf2dg3c00dd5d7486",
																	"value": "My pretty consort, I don't like to see doubt cast upon your face. Fear not: <i>you are mine</i>.",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "a18709c8-5f85-4398-bf98-0daf4a43f7e9"
																},
																"TagText": {
																	"handle": "hbdf8645egb64bg461eg9c58gd3f75390cefa",
																	"value": "Seven thousand souls have given me the power to carve out my own future, and I want you to be part of it.",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															}
														]
													}
												]
											}
										]
									}
								],
