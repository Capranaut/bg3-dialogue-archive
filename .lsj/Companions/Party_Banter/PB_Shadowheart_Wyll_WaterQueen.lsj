                                                "OldText" : {
                                                   "handle" : "h647fc5f5g65bag4e1fg8141g3d9169131f04",
                                                   "type" : 28, "value" : "Consider the numbers. Someone out there must be having the worst day of their life. Being robbed, evicted, widowed, who knows? Then, easy prey for Lady Shar.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h8a3bde06g2d56g4802g8676g0a731a4f98b7",
                                                   "type" : 28, "value" : "You'd be surprised how people can miss what's in plain sight. I missed the fact that Shar was deceiving me. Besides, I have a new look now. Suits me, I think.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
