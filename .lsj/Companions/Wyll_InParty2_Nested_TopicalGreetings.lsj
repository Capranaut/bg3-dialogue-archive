																	"value": "2ab3c4de-5470-46a7-b2e8-b69f772bfa95"
																},
																"TagText": {
																	"handle": "h9bde17fcg563cg4890gb660g663146184802",
																	"value": "But you said it anyway, to your immense credit. You're choosing truth, you're choosing freedom - for you, for Orpheus, for your people.",
																	"type": 28,
																	"version": 1
																},
