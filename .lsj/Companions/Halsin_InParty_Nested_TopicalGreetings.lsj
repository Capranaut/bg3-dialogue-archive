																	"handle": "h760041eegc5e3g4457g8577gbc9ba2d61029",
																	"value": "Shadowheart. Your tresses are... different. It suits you - though in truth, I cannot imagine much <i>does not </i>suit you.",
																	"type": 28,
																	"version": 2
																},
																"stub": {
