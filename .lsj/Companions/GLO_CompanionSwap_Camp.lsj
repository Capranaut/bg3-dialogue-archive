																},
																"TagText": {
																	"handle": "h595f599bge39cg4931gaed8ge4547949753d",
																	"value": "Relaxing by a fire while you run around doing all the hard work? Yes, that sounds like an excellent plan.",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
