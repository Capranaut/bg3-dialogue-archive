																	"value": "aa8744f0-aa3f-458b-8dc2-a5b76fa94b0c"
																},
																"TagText": {
																	"handle": "hd0e0fa6fg1480g443ag8409g9f8f6ab1421b",
																	"value": "Perhaps if you lost a follower or two. I prefer to travel in smaller groups - it's more intimate.",
																	"type": 28,
																	"version": 2
																},
																"stub": {
																	"type": 19,
