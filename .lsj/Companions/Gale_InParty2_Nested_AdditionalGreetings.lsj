													{
														"TagText": [
															{
																"LineId": {
																	"type": 22,
																	"value": "a9e3d334-77b0-424f-bc8d-e3f4a98eef4c"
																},
																"TagText": {
																	"handle": "hf05e819ag0e36g464agae43g521c173a8d6c",
																	"value": "Much as I enjoy our conversations, I think it's Elminster we should be catching up with. ",
																	"type": 28,
																	"version": 2
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "e53f9d6c-9c6f-492b-a04f-f2236907a689"
																},
																"TagText": {
																	"handle": "he12ffd24gdd64g4992gb79eg0652f2f530f0",
																	"value": "It doesn't do to keep a wizard waiting, especially one of Elminster's reputation. Not to mention appetite. We should join him in camp at the first opportunity.",
																	"type": 28,
																	"version": 3
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															}
