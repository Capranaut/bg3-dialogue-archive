													{
														"TagText": [
															{
																"LineId": {
																	"type": 22,
																	"value": "f697b32a-c68e-4fe2-b8a4-200568ac2765"
																},
																"TagText": {
																	"handle": "h14df7cd7g6f36g45b9gb6a9g9af1e390ffa9",
																	"value": "And use it to do more than fight, I'd hope. Shar and Selûne have already claimed more than their share of your years, I think.",
																	"type": 28,
																	"version": 1
																},
