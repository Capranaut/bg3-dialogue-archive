				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "In the fight against the Netherbrain and the Emperor, the Emperor brings Daisies to fight against players, based on their initial character creation choices. (Non-avatars get generic Daisies.)\r\n\r\nThis AD is used by any Daisy as they use their charming spells.\r\n\r\nDrop: Make target drop their weapon.\r\nGrovel: Set a character prone.\r\nFlee: Make a character frightened.\r\nHalt: Cannot move or take actions.\r\nHush: Silence."
				}
			}
