                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "feef6a53-0c30-4575-a705-f1f09871b027"},
                                                "OldText" : {
                                                   "handle" : "h4c652622g5cd2g4ea5g9ed1gb322c65ed9ff",
                                                   "type" : 28, "value" : "Well well, look at you. That painting must be worth a fortune...",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "hab337e0bgab51g4a20gbb57g6b934f88beb6",
                                                   "type" : 28, "value" : "Lorroakan's won immortality and all it took was heartless cruelty. A lesson, perhaps.",
                                                   "version" : 3
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 0},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_LAEZEL"}
                                                               }
                                                            ]
                                                         }
                                                      ],
                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "cac10cf2-dedc-4e05-9fca-7ec595b367f1"},
                                                "OldText" : {
                                                   "handle" : "hb0ada4f1g6ff6g4a68g837ag969735ab9179",
                                                   "type" : 28, "value" : "A stunning work. It would hold its own against the great githyanki frescos.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "ha47b1230g2c12g4fa6gb582g2268b34b2206",
                                                   "type" : 28, "value" : "There it is. A high price to pay for a stranger's immortality.<i><br></i>",
                                                   "version" : 3
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 0},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_GALE"}
                                                               }
                                                            ]
                                                         }
                                                      ],
                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "11916462-5cb3-4a3a-83a9-b2efa7eb79fe"},
                                                "OldText" : {
                                                   "handle" : "h12b28213g3b21g4f68g8d08g020e0c746b61",
                                                   "type" : 28, "value" : "A painting like that would fetch a fortune in Waterdeep. Or Baldur's Gate, for that matter.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "h8ed43ed6ga513g4cfbgb15dg25a94a750670",
                                                   "type" : 28, "value" : "Lorroakan's finally gained power worthy of his reputation. Not that he earned it.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 0},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_SHADOWHEART"}
                                                               }
                                                            ]
                                                         }
                                                      ],
                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "ecc68dd4-8503-4093-a1fd-78bca1fb7e6c"},
                                                "OldText" : {
                                                   "handle" : "h44cf91dag0c6dg4bedg8b07g8cf2b9a7e7c1",
                                                   "type" : 28, "value" : "I'm no expert, but that painting looks like it'd go for a nice sum.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "hb9ab328fgc642g412cg9096g3eb1acda5ac2",
                                                   "type" : 28, "value" : "Lorroakan has his immortality then. And Dame Aylin has lost her freedom - again.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 1},
                                                      "Tags" : [
