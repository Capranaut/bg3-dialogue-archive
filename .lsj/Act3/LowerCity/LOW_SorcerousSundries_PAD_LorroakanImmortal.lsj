                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "530b26c0-1f7d-4a2e-83ca-a275c0bec4a8"},
                                                "OldText" : {
                                                   "handle" : "h4592f16dg5bc6g4718g8a2dga2b8702ae363",
                                                   "type" : 28, "value" : "Delicate brushstrokes, exquisite use of colour. This is no amateur work.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "h45ffafa3gde7ag42eeg9ddfgf1049a3e9490",
                                                   "type" : 28, "value" : "Immortality - and all it took was a betrayal of the highest order.<i><br></i>",
                                                   "version" : 3
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
