                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "cd10a24a-7f72-45da-ae94-638bf48e4258"},
                                                "OldText" : {
                                                   "handle" : "h2da55156gb9dag45f6g892ag133c28a4b084",
                                                   "type" : 28, "value" : "Most of the art here is dross, but that one looks rather valuable.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "hda95b467g2a94g4af8ga1bfgfcaf6dd83e79",
                                                   "type" : 28, "value" : "It is sickening to think a man like Lorroakan might live forever. I would prefer he didn't live another hour.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 0},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_MINSC"}
                                                               }
                                                            ]
                                                         }
