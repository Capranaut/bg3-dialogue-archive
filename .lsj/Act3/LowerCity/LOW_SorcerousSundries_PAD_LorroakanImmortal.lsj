                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 0},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_KARLACH"}
                                                               }
                                                            ]
                                                         }
                                                      ],
                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "f36d9fe3-550b-4df7-9f5f-64663f6e4abf"},
                                                "OldText" : {
                                                   "handle" : "he7da6849g8866g45f9g8109g50ee5651ffb9",
                                                   "type" : 28, "value" : "Ooh. Looks expensive.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "hb3f3b611g546dg4d21g844ag31d6fa1cf1af",
                                                   "type" : 28, "value" : "There you have it. The worst decision we've made.",
                                                   "version" : 3
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 0},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_JAHEIRA"}
                                                               }
                                                            ]
                                                         }
                                                      ],
                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "6b3bfc8a-5995-4c1e-b088-bc13f582704f"},
                                                "OldText" : {
                                                   "handle" : "h39a1cb00gc831g4b55g8361g2a0fcbb111fb",
                                                   "type" : 28, "value" : "I am no critic, but I've seen nobles throw coin at so pretty a piece as that.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "h8cc30a15gc983g4c29gad63gb82d788fb144",
                                                   "type" : 28, "value" : "Dame Aylin saved our hides - and now we let Lorroakan perch on her back and call himself might.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 0},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_HALSIN"}
                                                               }
                                                            ]
                                                         }
                                                      ],
                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "4963a6d4-f2f6-47ae-ac66-1404a022f01c"},
                                                "OldText" : {
                                                   "handle" : "he1a4f623g07c7g47f6g86a0g2b18fbc0c681",
                                                   "type" : 28, "value" : "I prefer the art that nature provides, yet I would wager that painting is of great value.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "h7283ff3fgbadbg4ba7g8924g77a7a7c5f551",
                                                   "type" : 28, "value" : "Lorroakan has his immortality at last. And we have lost a great ally.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
