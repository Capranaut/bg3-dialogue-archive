                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "e241398d-782b-41bf-98c5-e9ffd5a9724e"},
                                                "OldText" : {
                                                   "handle" : "h9cec852fg7139g4ed0ga4a1gddd6470bb693",
                                                   "type" : 28, "value" : "Boo judges this one to be the best. But perhaps you should not listen, until you have seen how he has decorated his burrow.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "hda9109c1g63a4g4c7bg8340g0aa626dbbea5",
                                                   "type" : 28, "value" : "Faugh. This place still stinks of our treachery. Breathe deep of betrayal, Boo.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
