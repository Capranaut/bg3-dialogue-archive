                                                "OldText" : {
                                                   "handle" : "ha529a84fg8a9eg4c9egaa64g87f4efdd9d34",
                                                   "type" : 28, "value" : "A fine painting. Should be worth its weight in gold.",
                                                   "version" : 3
                                                },
                                                "TagText" : {
                                                   "handle" : "hc59a434fg4c59g4e23g8d41gbaac18714404",
                                                   "type" : 28, "value" : "There we have it. Lorroakan the immortal.",
