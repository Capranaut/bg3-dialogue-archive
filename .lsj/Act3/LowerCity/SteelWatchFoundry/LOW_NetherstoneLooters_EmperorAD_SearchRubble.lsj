				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "A player left a Netherstone on the ground inside the Steel Watch Foundry before they blew it up.The Emperor is not very impressed and directs them towards the rubble to try finding them. They'll encounter a small group of Kobolds digging through the rubble who will be holding them. On entering combat, they'll run away."
				}
			}
