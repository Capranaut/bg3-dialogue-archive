				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "A player left a Netherstone on the ground inside the Steel Watch Foundry before they blew it up.The player spots the looters who have the Netherstones and must chase after them. Once they get the stones back, the Emperor expresses relief and a bit of frustration."
				}
			}
