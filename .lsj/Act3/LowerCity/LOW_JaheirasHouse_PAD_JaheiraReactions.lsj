													"value": "InternalNodeContext"
												},
												"val": {
													"type": 23,
													"value": "May or may not be going a bit hardcore into Odysseus's ship as a throwaway line here, but oh well."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "IsCustomNode"
												},
												"val": {
													"type": 23,
													"value": "False"
