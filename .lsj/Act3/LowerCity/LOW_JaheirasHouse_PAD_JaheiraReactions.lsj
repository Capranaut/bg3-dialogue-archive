												}
											},
											{
												"key": {
													"type": 22,
													"value": "NodeContext"
												},
												"val": {
													"type": 23,
													"value": "This is in reference to her husband Khalid, who died violently over a century previously. It came close to breaking her at the time, but now there is only fondness for the man she remembers. The gift is a spider-silk amulet with a gem at its centre, made with Khalid's own hands."
												}
											},
											{
