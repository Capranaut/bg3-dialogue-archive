                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "c1b2effa-b013-434e-a760-a6f16e39e0aa"},
                                                "OldText" : {
                                                   "handle" : "h212c982fg95ffg4c68ga6a8g6badb24ac10f",
                                                   "type" : 28, "value" : "That was easy. ",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h8247f919g11a6g44a9g8a47gba4e18a3bbc1",
                                                   "type" : 28, "value" : "Might be some interesting stuff down here. You first.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
