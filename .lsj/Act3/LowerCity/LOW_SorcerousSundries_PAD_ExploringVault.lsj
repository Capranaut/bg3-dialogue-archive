                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "6afdb148-88f9-4653-a425-07cfd0f6ac22"},
                                                "OldText" : {
                                                   "handle" : "h0c5d7a2dg8c9ag4b26gbac8g60a3f4a9a7da",
                                                   "type" : 28, "value" : "Well, that was easy. She'll deliver herself straight to Lorroakan.",
                                                   "version" : 2
                                                },
                                                "TagText" : {
                                                   "handle" : "haf4708d0g1f3ag4057gad18g463cc9b8a224",
                                                   "type" : 28, "value" : "Now this seems like an excellent place to liberate some expensive magical trinkets.",
                                                   "version" : 1
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
