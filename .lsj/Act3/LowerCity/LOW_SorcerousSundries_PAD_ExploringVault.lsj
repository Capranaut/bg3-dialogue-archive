                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "071ab88a-7fcb-4c46-ba1c-295bb154b9f7"},
                                                "OldText" : {
                                                   "handle" : "hf9e5b41fg1df9g4d4bg9f58g538c915232b0",
                                                   "type" : 28, "value" : "Too trusting for her own good. Dame Aylin's Lorroakan's for the taking now.",
                                                   "version" : 2
                                                },
                                                "TagText" : {
                                                   "handle" : "h6f43675fg1c7cg4b59ga760gc9743f71b60d",
                                                   "type" : 28, "value" : "Powerful artefacts, sat here gathering dust... I'm sure there's no harm in borrowing some.",
                                                   "version" : 1
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
