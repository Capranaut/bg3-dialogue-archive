                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "004bf574-b4e3-447b-adba-7387a839733a"},
                                                "OldText" : {
                                                   "handle" : "hb222dabdg1317g43b3gb1ffg6c928e01ff1f",
                                                   "type" : 28, "value" : "We have deceived Dame Aylin, and sent her to a trap... is this how we treat friends and allies?",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h6a7a8930g975bg4cd4g994dgc5baf975c72f",
                                                   "type" : 28, "value" : "This tower will hide a great number of magic valuables, should we care to look.",
                                                   "version" : 1
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
