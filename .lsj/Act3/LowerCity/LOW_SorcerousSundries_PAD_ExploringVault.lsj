                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "d6153cee-605b-4b14-88f7-cc34a04d6222"},
                                                "OldText" : {
                                                   "handle" : "h92811549g149eg4ad7gb8f1g477fc7133878",
                                                   "type" : 28, "value" : "We set Aylin on the warpath without telling her exactly what it is she's charging into.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h791b2e00gbb69g4cafg89f0gbf6151b0f10f",
                                                   "type" : 28, "value" : "Ah - we might find some dustier stock down here. The kind of thing a wizard would keep from the public eye.",
                                                   "version" : 1
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
