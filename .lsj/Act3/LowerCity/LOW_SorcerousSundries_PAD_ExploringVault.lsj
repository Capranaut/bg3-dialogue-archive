                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "12f552e1-1b2c-404a-a880-3ba69af57d44"},
                                                "OldText" : {
                                                   "handle" : "h689a7123gd484g45a1g84e7g4f9b5c1d6c3a",
                                                   "type" : 28, "value" : "Sending Aylin into the wizard's clutches does not sit right with me. He is a worm.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h6909aee5g8c17g42f2ga3f8g92b52f28c9a0",
                                                   "type" : 28, "value" : "Emptying a wizard's vault of its treasures is one of life's great joys. They have such wonderful playthings.",
                                                   "version" : 1
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 0},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_MINSC"}
                                                               }
                                                            ]
                                                         }
                                                      ],
                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "6af6edeb-0b73-417b-8e51-531dab594fe5"},
                                                "OldText" : {
                                                   "handle" : "h9eada850g0f17g46adg89bfgf942881e2e7b",
                                                   "type" : 28, "value" : "Did you just lie to an angel? Make this right, my friend, or they will spawn a tenth and special hell, just for you.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h4bb021c2gcba5g4800ga040g23af9e1fb7d8",
                                                   "type" : 28, "value" : "Do you smell something of devastating magical power, Boo? Or - perhaps a larger sword?",
                                                   "version" : 1
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
