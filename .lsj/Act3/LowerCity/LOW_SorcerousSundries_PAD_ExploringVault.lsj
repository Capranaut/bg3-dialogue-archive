                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "337ea3f6-64f5-494d-a3e6-6f342973407c"},
                                                "OldText" : {
                                                   "handle" : "h10586c5eg5decg4ae9gbb3dgb7302491e442",
                                                   "type" : 28, "value" : "She'll walk right into Lorroakan's trap. Or fly, perhaps.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "hab675208g7ea4g4f4ag954eg4ca5fae0189a",
                                                   "type" : 28, "value" : "The perfect chance to liberate some magic valuables, I think.",
                                                   "version" : 1
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
                                       {
                                          "Rules" : [
                                             {
                                                "Rule" : [
                                                   {
                                                      "HasChildRules" : {"type" : 19, "value" : 0},
                                                      "TagCombineOp" : {"type" : 1, "value" : 1},
                                                      "Tags" : [
                                                         {
                                                            "Tag" : [
                                                               {
                                                                  "Object" : {"type" : 22, "value" : "REALLY_WYLL"}
                                                               }
                                                            ]
                                                         }
                                                      ],
                                                      "speaker" : {"type" : 4, "value" : 0}
                                                   }
                                                ]
                                             }
                                          ],
                                          "TagCombineOp" : {"type" : 1, "value" : 0}
                                       }
                                    ],
                                    "TagTexts" : [
                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "83da5365-fd9c-418a-8a2c-3eec9166a155"},
                                                "OldText" : {
                                                   "handle" : "h857b4f53g6771g414agbb66g6deb870fdd7b",
                                                   "type" : 28, "value" : "There she goes. And we're just going to let her walk into the wizard's trap?<i><br></i>",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h8f2eb255g50b6g4cddgbbabgfcc6b0e72ab2",
                                                   "type" : 28, "value" : "Well. I suppose it wouldn't hurt if I poked around a little.<i><br></i>",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
                                 {
                                    "HasTagRule" : {"type" : 19, "value" : 1},
                                    "RuleGroup" : [
