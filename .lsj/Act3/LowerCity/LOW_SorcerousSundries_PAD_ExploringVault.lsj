                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "dfbbc7fb-d36c-4d52-8384-e0cb3fa99c20"},
                                                "OldText" : {
                                                   "handle" : "hcf63dc42g2555g47f6ga382g3469fd3eaf0d",
                                                   "type" : 28, "value" : "Off she goes. This won't end well for the Nightsong.<br><i><br></i>",
                                                   "version" : 2
                                                },
                                                "TagText" : {
                                                   "handle" : "hccdfd7c0gdc43g4e91gadf3g07b8b0312724",
                                                   "type" : 28, "value" : "There must be all manner of magical trinkets down here.<i><br></i>",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
