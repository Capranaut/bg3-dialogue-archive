														"TagText": [
															{
																"LineId": {
																	"type": 22,
																	"value": "32a9fafb-f9f1-4e88-846b-bc842ff43b9f"
																},
																"TagText": {
																	"handle": "h7d7be0e8geef9g4c5dga3e6g08d7e1cb06a2",
																	"value": "|  She always sat here when we conducted our business. It pleased me to stand while she laboured. Note the chair is impressive though - all the better to maintain the illusion of control where there was none. Of course, I grew fond of that chair. Even after her death, I never discarded it. It gave me comfort to see her in my mind's eye, sitting there in all her seriousness as I conducted her affairs. |<br>",
																	"type": 28,
																	"version": 2
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															}
														]
													}
