			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "1. WYR, Sharess Caress, RAphael's room\r\n2. Make deal with Raphael\r\n3. Teleport to LOW, HoH\r\n4. Teleport to Incubus, kill him, loot his key\r\n5. Open big painting on the wall behind him. Loot and read note.\r\n6. Teleport to Archivist.\r\n7. Click on big barrel with contract. Choose the password you read on the note.\r\n8. Take contract. Interact with it in inventory"
				},
