													"type": "FixedString",
													"value": "AnimationTags"
												},
												"val": {
													"type": "LSString",
													"value": "[KAYLEIGH] Saverok reaches his hand out with purpose, clenches it tight as if grasping the power send to him and pulls it back."
												}
											},
											{
												"key": {
													"type": "FixedString",
													"value": "Attitude"
