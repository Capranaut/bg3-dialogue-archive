					"type": 19,
					"value": 0
				},
				"nextNodeId": {
					"type": 5,
					"value": 1
				},
				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "The party reacts to becoming an Unholy Assassin in the Bhaalist Murder Tribunal. This means Valeria was killed by either us or some other party member - if she was killed before we reached the Tribunal, her corpse will be here and we still bathe in her blood. Different companions will have different reactions to what they just did in order to become an Unholy Assassin."
				}
			}
		}
