															{
																"LineId": {
																	"type": 22,
																	"value": "c5894e7e-4a7e-4c82-b0ca-fe14e8aade06"
																},
																"TagText": {
																	"handle": "h7131e0fdgaa41g47b5gb33eg24892243317f",
																	"value": "The way I see it, you've got the folk who invest in quality armour, and you've got the corpses who tried to play it cheap.",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "ecce477f-b5e4-40fa-b330-2270665974b3"
																},
																"TagText": {
																	"handle": "h7ff2d8ddg96bag4782gb07ag3eb0071a2c83",
																	"value": "City's got a dangerous air to it these days. Only makes sense to take self-preservation measures.",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "64db9dcd-a59e-40a4-85aa-1ef31000b663"
																},
																"TagText": {
																	"handle": "h34aab1eeg3ea2g499fgbdaeg13e68ee2cd19",
																	"value": "Truth be told, I wear chain mail to bed these days. I've heard too many stories to take any chances.",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															}
