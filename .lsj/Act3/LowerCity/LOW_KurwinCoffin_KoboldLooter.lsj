			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "- Find the coffin by either knowing about the note and finding the specific grave, or by going on a looting spree in a graveyard\r\n- Dig it up and open it for a surprise Bugthimble!\r\n\r\nBookmark: larian://bookmark?name=BGO_KurwinCoffin&mod=GustavDev&level=BGO_Main_A&camPos=-1744.178589;42.883114;706.366821&camTarget=-1743.758667;42.415478;705.588989"
				},
