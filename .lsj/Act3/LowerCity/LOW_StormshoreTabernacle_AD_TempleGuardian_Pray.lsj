			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "The character S_LOW_TempleGuardian_32ec6ad3-c085-4fc5-943b-e2e3a05d9f2b will move to the point (TRIGGER)S_LOW_StormshoreTabernacle_PrayPoint_9afca468-b88c-4355-b34d-ea858ed14eaf steer to the shrine S_LOW_GenericGodStatue_d71704b6-24b6-46b7-982c-89acb3edfc20 and pray."
				},
