												},
												"val": {
													"type": 23,
													"value": "[Dammon] recieves something while delivering line, turns to forge and then returns it to the player <Greg>, , *REUSE* [Player] CINE_ProduceInventory_StandL_01-03 <Lili>"
												}
											},
