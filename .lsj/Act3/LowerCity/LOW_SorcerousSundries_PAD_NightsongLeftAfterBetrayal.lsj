                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "f6a88699-fa4d-4160-8f09-c71af55a148e"},
                                                "OldText" : {
                                                   "handle" : "haf4708d0g1f3ag4057gad18g463cc9b8a224",
                                                   "type" : 28, "value" : "Now this seems like an excellent place to liberate some expensive magical trinkets.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "hfa244b03gf3a9g42a8gbb9eg82bbf14ebc0d",
                                                   "type" : 28, "value" : "I suppose this means Rolan didn't bind Dame Aylin. Bad news for him and bad news for us.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
