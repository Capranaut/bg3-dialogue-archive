                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "e02d32df-3538-4d3b-85b8-cff70cdd1e63"},
                                                "OldText" : {
                                                   "handle" : "h6909aee5g8c17g42f2ga3f8g92b52f28c9a0",
                                                   "type" : 28, "value" : "Emptying a wizard's vault of its treasures is one of life's great joys. They have such wonderful playthings.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h7c7375cdg5765g4676gbc4cg9105f76ab7be",
                                                   "type" : 28, "value" : "I am always cheered by the sight of a dead wizard... but it seems Aylin escaped. She may seek vengeance against us.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
