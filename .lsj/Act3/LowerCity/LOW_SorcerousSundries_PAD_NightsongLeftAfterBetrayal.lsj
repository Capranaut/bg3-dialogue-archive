                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "9f049aa3-6c0e-4eec-9172-de6526a2a775"},
                                                "OldText" : {
                                                   "handle" : "h8247f919g11a6g44a9g8a47gba4e18a3bbc1",
                                                   "type" : 28, "value" : "Might be some interesting stuff down here. You first.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h203c28f0gcdadg4464g8c37gd9d005a65288",
                                                   "type" : 28, "value" : "Looks like Rolan didn't figure out how to bind Dame Aylin. Powerful enemy we've made.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
