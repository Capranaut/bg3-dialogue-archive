                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "4d15f0df-17ac-4987-b180-66c1f6d9b8e1"},
                                                "OldText" : {
                                                   "handle" : "h4bb021c2gcba5g4800ga040g23af9e1fb7d8",
                                                   "type" : 28, "value" : "Do you smell something of devastating magical power, Boo? Or - perhaps a larger sword?",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h2a9a33ebg5d02g4becgb063g74889d1c4e2c",
                                                   "type" : 28, "value" : "The little wizard could not hold Aylin. May she return and rain armoured boots upon our faithless skulls.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
