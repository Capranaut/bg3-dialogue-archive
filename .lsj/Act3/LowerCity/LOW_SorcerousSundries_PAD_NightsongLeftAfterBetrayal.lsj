                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "6fbe23e2-8f99-4213-a32e-635ae4e64b42"},
                                                "OldText" : {
                                                   "handle" : "h791b2e00gbb69g4cafg89f0gbf6151b0f10f",
                                                   "type" : 28, "value" : "Ah - we might find some dustier stock down here. The kind of thing a wizard would keep from the public eye.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h42e1e555g6d3bg493fg8488gb05168cd15db",
                                                   "type" : 28, "value" : "The prentice wizard could not master the Nightsong. We might taste Aylin's righteous anger ourselves, yet.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
