                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "d02ffc1d-d7cf-4f5a-b406-e7edfadf3eb7"},
                                                "OldText" : {
                                                   "handle" : "h8f2eb255g50b6g4cddgbbabgfcc6b0e72ab2",
                                                   "type" : 28, "value" : "Well. I suppose it wouldn't hurt if I poked around a little.<i><br></i>",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h07ce187fgd483g48c6gb6f1gf0d1b778ae15",
                                                   "type" : 28, "value" : "Dame Aylin's slipped through Rolan's fingers. I wager she'll be back - and not in the best of moods.<i><br></i>",
                                                   "version" : 3
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
