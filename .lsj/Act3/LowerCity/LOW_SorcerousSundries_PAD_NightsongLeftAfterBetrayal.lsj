                                       {
                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "5ce58d2f-4729-4319-ae5e-b3066339b107"},
                                                "OldText" : {
                                                   "handle" : "h6a7a8930g975bg4cd4g994dgc5baf975c72f",
                                                   "type" : 28, "value" : "This tower will hide a great number of magic valuables, should we care to look.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "hfb28e5f4g94bbg4ad9g9a0dg42697a0c7ac0",
                                                   "type" : 28, "value" : "It seems Rolan failed to bind Dame Aylin in time. And now she shall see us as enemies.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
