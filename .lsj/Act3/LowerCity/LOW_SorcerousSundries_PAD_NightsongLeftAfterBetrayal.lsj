                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "8b70312a-90b3-4dfe-8716-b78979a5c921"},
                                                "OldText" : {
                                                   "handle" : "h6f43675fg1c7cg4b59ga760gc9743f71b60d",
                                                   "type" : 28, "value" : "Powerful artefacts, sat here gathering dust... I'm sure there's no harm in borrowing some.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h02fa7f44g421bg4420g9425g879c49a39923",
                                                   "type" : 28, "value" : "Aylin made short work of Rolan. If its revenge she wants, I'll have to show her some real wizardry.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
