                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "1bb97000-ed51-4fd7-a5e7-10bfa9a5c088"},
                                                "OldText" : {
                                                   "handle" : "hccdfd7c0gdc43g4e91gadf3g07b8b0312724",
                                                   "type" : 28, "value" : "There must be all manner of magical trinkets down here.<i><br></i>",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "hf4f9ff20g4fa3g42bfg90f0ge0187801da15",
                                                   "type" : 28, "value" : "Dame Aylin's nowhere in sight. If Rolan failed, I've a new enemy to contend with.",
                                                   "version" : 3
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
                                 },
