                                          "TagText" : [
                                             {
                                                "LineId" : {"type" : 22, "value" : "e8fddb8c-1959-40c0-8b35-c8fdc419b15e"},
                                                "OldText" : {
                                                   "handle" : "hab675208g7ea4g4f4ag954eg4ca5fae0189a",
                                                   "type" : 28, "value" : "The perfect chance to liberate some magic valuables, I think.",
                                                   "version" : 1
                                                },
                                                "TagText" : {
                                                   "handle" : "h20675ef4g4e03g4420ga0a8gdd713a533c06",
                                                   "type" : 28, "value" : "Looks like Dame Aylin evaded Rolan. She won't be pleased, next time she appears.",
                                                   "version" : 2
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             }
                                          ]
                                       }
                                    ]
