																	"value": "a7ac0c11-46ec-45d0-b6b7-2dcab48fa7f1"
																},
																"TagText": {
																	"handle": "h6ef23075g61a3g4c1fga7a2gaf2f537e392c",
																	"value": "But Baldur's Gate isn't out of danger yet, is it? Gortash was one bad actor. Delightful you stomped the light out of him. But from what I hear, there could be more.",
																	"type": 28,
																	"version": 2
