			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "Load SCL_Main, in debug book choose \"Set quest flags & options\" -> Act3 -> Ironhand gnomes -> Setup all gnomes -> Setup Oppress Scene. Then through debug book \"Go to region\" -> Act3 -> WYR -> Ironhand gnomes hideout. Walk in sight of any gnome in the basement."
				},
				"defaultAttitudes": [
					{
