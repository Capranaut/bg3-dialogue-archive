											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[GERRY] Skeletal Dragon Rising-Bones shake and rattle as he ‘assembles’, looming over player, terrifying and menacingPlayer: Comes to after being dazed from being struck by lightening. Turns around on floor to witness. Looking up at dragon from the floor in shock (idling). See Storyboard and kickoff doc for ref."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "The energy flows into the dragon bones on the ground. Ghostly lights spark inside the eye sockets of the skull.\r\n\r\nJLatino: CUT \"A skeletal dragon assembles and rises, looming over the players, terrifying in its presence.\""
												}
											},
