										"data": [
											{
												"key": {
													"type": 22,
													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[GERRY] Ravengard walks down the steps with the sword of Balduran held pointed down in two hands close to his chest and steps forward in front of Gortash into the same looping Idle from the top of the stairs., , Gortash is still kneeling(looping idle), back to player as Ravenguard ends his walk, Gortash looks down into the looping idle of 'kneeling looking down'., , Everyone takes position for the Archduke ceremony going from Staging 03 to Staging 04."
												}
											},
											{
												"key": {
													"type": 22,
													"value": "Attitude"
												},
												"val": {
													"type": 23,
													"value": "Default"
												}
											},
											{
												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "Gortash approaches Ravengard. Ravengard nods and steps forward. He holds a sword aloft - the sword of Balduran, perhaps. Gortash kneels, back to player. Everyone takes position for the Archduke ceremony."
												}
											},
