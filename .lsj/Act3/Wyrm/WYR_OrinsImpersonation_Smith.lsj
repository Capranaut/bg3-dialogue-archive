															{
																"LineId": {
																	"type": 22,
																	"value": "9bd25d53-2ad3-4c43-ae7c-9a3cf2a7dec8"
																},
																"TagText": {
																	"handle": "h841eb739g3876g4db2gaf32g9ae1a6e81fbe",
																	"value": "Those gnomes are <i>victims</i>. They've spent years in exile, no forge to call their own, all because of some ancient bloody grudge.",
