				"speakerSlotDescription": [
					{}
				],
				"synopsis": {
					"type": 23,
					"value": "During the zombie combat in the Sentient Amulet situation, the monk will be possessing one of the zombies. If the possessed zombie goes below half health, the monk will hop to another zombie and heal it. This AD will play on the possessed zombie if there are no other zombies available to possess."
				}
			}
