													"value": "AnimationTags"
												},
												"val": {
													"type": 23,
													"value": "[LOGAN] PLYR dispatches the Attacker (off cam) with a quick slit of the throat. The attacker lies dead for a few beats, before his head turns back to the PLYR, smiling. Knife disintergrates in PLYR's hand, to their shock."
												}
											},
											{
												"key": {
													"type": 22,
