												"key": {
													"type": 22,
													"value": "CinematicNodeContext"
												},
												"val": {
													"type": 23,
													"value": "The player dispatches the dying man (off camera). They appear upset/ unhappy at their task. We see the dead man still for a beat. Then he turns to us. The knife in the player's hand disintegrates - one of Orin's illusions."
												}
											},
