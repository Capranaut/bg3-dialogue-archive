																},
																"TagText": {
																	"handle": "hb3fbfe26g00d0g437agab14g71a32c41f7fe",
																	"value": "What spell? You've simply fallen for my devilishly attractive features and enigmatic persona. Happens all the time.",
																	"type": 28,
																	"version": 4
																},
																"stub": {
																	"type": 19,
