																	"type": 22,
																	"value": "975984c5-c675-44b2-a862-9902e74fd8e9"
																},
																"TagText": {
																	"handle": "h39c0434dg7ec8g4939ga1c4g19304b5eb2ff",
																	"value": "Come now. I have no need to cast a spell to charm someone. I can achieve that all by myself.",
																	"type": 28,
																	"version": 3
																},
																"stub": {
