			"editorData": {
				"HowToTrigger": {
					"type": 23,
					"value": "Commit a crime in a region with a prison (e.g. the DEN)\r\nGet arrested and go to prison\r\nTeleport out of prison in front of civilians (e.g. the packing tiefling couple)\r\nShapeshift while they can see you."
				},
