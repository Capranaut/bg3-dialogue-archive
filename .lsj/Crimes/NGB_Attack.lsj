                                                "TagText" : {
                                                   "handle" : "ha373e4cega06cg42aega763g49e2e03e7ea2",
                                                   "type" : 28, "value" : "*Your behaviour has caused upset. Now a fight is unavoidable.*",
                                                   "version" : 3
                                                },
                                                "stub" : {"type" : 19, "value" : 1}
                                             },
                                             {
