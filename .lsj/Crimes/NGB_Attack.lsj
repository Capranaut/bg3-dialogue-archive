                                                "LineId" : {"type" : 22, "value" : "7b61e36f-c6fb-902f-9934-2e2cda550f68"},
                                                "TagText" : {
                                                   "handle" : "h50007ea4gab4dg4d7fg8137g0c890f5aaec4",
                                                   "type" : 28, "value" : "*There's no talking your way out of this. You'll have to defend your actions the old-fashioned way.*",
