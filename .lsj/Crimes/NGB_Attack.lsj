                                                "TagText" : {
                                                   "handle" : "h6ff9e161g4e7fg475bgbbe1g8c98479636de",
                                                   "type" : 28, "value" : "*Your actions have drawn the ire of someone nearby. A fight is inevitable.*",
                                                   "version" : 4
