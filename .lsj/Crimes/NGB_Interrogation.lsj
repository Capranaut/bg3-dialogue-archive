														"TagText": [
															{
																"LineId": {
																	"type": 22,
																	"value": "a00b5a49-6f07-4265-9590-b0ceb614107d"
																},
																"TagText": {
																	"handle": "h7d6f9201ge20cg4919g8072ga0a44444bc87",
																	"value": "*Gold may have made your problem go away this time, but next time you won't be so lucky.*",
																	"type": 28,
																	"version": 3
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "d1545b26-0dbc-422a-a165-2eeb9aaf6c1b"
																},
																"TagText": {
																	"handle": "h73a20007g6130g4504gbdefg29ab1d66ccd8",
																	"value": "*The benefit of the doubt can only be bought so many times. This was the last of those times.*",
																	"type": 28,
																	"version": 3
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "2baaeb84-52cc-4dcc-a3ae-3bf636aabf15"
																},
																"TagText": {
																	"handle": "hb6420d9dg6b13g473agbc7dg5c3ec3ce088a",
