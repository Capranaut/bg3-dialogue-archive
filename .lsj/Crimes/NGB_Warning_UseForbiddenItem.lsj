																},
																"TagText": {
																	"handle": "h1c0db051g4882g4c55g84e8gf256963ec5ac",
																	"value": "*Tempers are rising. It's clear not everything you find is at your disposal.*",
																	"type": 28,
																	"version": 5
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "270a1e1d-ac44-c589-5676-a6ff612fbf98"
																},
																"TagText": {
																	"handle": "h1813adaag3517g4693gaf86g7eb8885d9803",
																	"value": "*Not for communal use, it seems. Best show some respect - or some more cunning.*",
																	"type": 28,
																	"version": 3
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
