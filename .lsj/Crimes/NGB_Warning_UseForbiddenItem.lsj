																"LineId": {
																	"type": 22,
																	"value": "88320d39-3c11-0ac1-d119-d43e5b396e5e"
																},
																"TagText": {
																	"handle": "h0bcd5e5cg9febg4f8ag935cg50afbc98b398",
																	"value": "*Best keep your hands to yourself. You're being watched.*",
																	"type": 28,
																	"version": 4
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
