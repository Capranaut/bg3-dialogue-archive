												"TagTexts": [
													{
														"TagText": [
															{
																"LineId": {
																	"type": 22,
																	"value": "41964cba-132f-4832-a006-451327f955e2"
																},
																"TagText": {
																	"handle": "hec0b9e9bgc6b8g4df5g9f90g9cf5a7d45966",
																	"value": "*Your apologetic tone makes little difference. Your theft has earned you a bed in the cells.*",
																	"type": 28,
																	"version": 2
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "bffe315e-8872-4d20-afe8-c4ceb0e6053f"
																},
																"TagText": {
																	"handle": "h6e414422g39b8g49adga94agcf1ff29672a3",
																	"value": "*Your feigned ignorance falls on disinterested ears. A thief is a thief, and belongs in prison.*",
																	"type": 28,
																	"version": 2
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "b1f81de7-676d-4326-b971-2f7340540769"
																},
																"TagText": {
																	"handle": "h03ed2700g6b62g4b95gb1d9gc63985d2bf86",
																	"value": "*Returning the stolen items, while commendable, stil amounts to a confession. A prison cell beckons...*",
																	"type": 28,
																	"version": 2
																},
																"stub": {
																	"type": 19,
																	"value": 1
																}
															},
															{
																"LineId": {
																	"type": 22,
																	"value": "ba7903ab-04bd-4e0e-bdbe-55b4a599f269"
																},
																"TagText": {
																	"handle": "h2cb20283gedb4g43eagb097g26b0b45f63c0",
																	"value": "*Your apparent naivety is not convincing enough. Accident or not, you're about to be arrested.*",
																	"type": 28,
																	"version": 1
																},
																"stub": {
																	"type": 19,
																	"value": 1
